---
import Layout from "../../layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import Button from "@/components/ui/button.astro";
import ProfileContent from "@/components/profile/ProfileContent.astro";
import { maybeGetLoggedInProfile } from "@/lib/profile";

const profile = await maybeGetLoggedInProfile({
  request: Astro.request,
  cookies: Astro.cookies,
  type: "full",
});

let collections: string[] = [];
if (profile) {
  try {
    const response = await fetch(
      `https://public.api.bsky.app/xrpc/com.atproto.repo.describeRepo?repo=${encodeURIComponent(profile.did)}`,
    );
    if (response.ok) {
      const data = await response.json();
      collections = data.collections ?? [];
    }
  } catch (e) {
    // collections stays empty
  }
}
---

<Layout title="Profile - Atmosphere Conference">
  <div class="w-full">
    <Card class="max-w-2xl mx-auto mt-8 p-8">
      {!profile ? (
        <div class="text-center">
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Error</h2>
          <p class="text-gray-600 mb-4">Failed to load profile</p>
          <Button href="/logout">Logout</Button>
        </div>
      ) : (
        <ProfileContent
          did={profile.did}
          handle={profile.handle}
          displayName={profile.displayName}
          avatarUrl={profile.avatarUrl}
          description={profile.confProfile?.description}
          homeTown={profile.confProfile?.homeTown}
          interests={profile.confProfile?.interests}
          isOwnProfile={true}
          collections={collections}
        />
      )}
    </Card>
  </div>
</Layout>
