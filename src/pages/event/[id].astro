---
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import BookmarkIcon from "@/components/ui/BookmarkIcon.astro";
import { getLiveEntry } from "astro:content";
import { formatConferenceDay, formatConferenceTime } from "@/lib/datetime";
import calendarIconSvg from "@/components/ui/icons/CalendarIcon.svg?raw";
import clockIconSvg from "@/components/ui/icons/ClockIcon.svg?raw";
import mapPinIconSvg from "@/components/ui/icons/MapPinIcon.svg?raw";
import remoteBadgeSvg from "@/components/ui/icons/RemoteBadge.svg?raw";
import inPersonIconSvg from "@/components/ui/icons/InPersonIcon.svg?raw";
import { isRemoteAccessible } from "@/lib/calendar-event";

const { id } = Astro.params;
const user = Astro.locals.loggedInUser;

const streamTracks = [
  { id: "stream1", name: "Stream 1", room: "Great Hall South" },
  { id: "stream2", name: "Stream 2", room: "Performance Theatre" },
  { id: "stream3", name: "Stream 3", room: "Room 2301" },
];

const { entry, error } = await getLiveEntry("events", id!);
if (error) {
  throw error;
}

const showTypes = new Set([
  "presentation",
  "lightning-talk",
  "panel",
  "workshop",
]);

if (!entry || !showTypes.has(entry.data.type)) {
  return Astro.redirect("/talks");
}

const {
  title,
  type,
  mode,
  speakers,
  description,
  category,
  room,
  start,
  end,
  headerUrl,
} = entry.data;

const typeNames: Record<string, string> = {
  presentation: "Presentation",
  "lightning-talk": "Lightning Talk",
  panel: "Discussion / Panel",
  workshop: "Workshop",
};

const badgeColors: Record<string, string> = {
  presentation: "event-badge event-badge-presentation",
  "lightning-talk": "event-badge event-badge-lightning",
  panel: "event-badge event-badge-panel",
  workshop: "event-badge event-badge-workshop",
};

const plainTitle = title.replace(/<[^>]*>/g, "");

const timeDisplay =
  start && end
    ? `${formatConferenceTime(start)} – ${formatConferenceTime(end)} PT`
    : start
      ? `${formatConferenceTime(start)} PT`
      : null;

const dateDisplay = start ? formatConferenceDay(start) : null;

const streamTrack = isRemoteAccessible(mode)
  ? streamTracks.find((t) => t.room === room)
  : null;
---

<Layout
  title={`${plainTitle} — ATmosphereConf 2026`}
  ogImage={headerUrl}
  page="event"
>
  <div class="mt-20 space-y-10">
    <div class="event-card-wrap">
      <button
        class="bookmark-ribbon"
        data-star-btn={id}
        aria-label="Bookmark this session"
        aria-pressed="false"
        title="Bookmark this session"
      >
        <BookmarkIcon
          class="bookmark-icon bookmark-icon-empty"
          strokeWidth={1.5}
        />
        <BookmarkIcon
          class="bookmark-icon bookmark-icon-filled"
          filled
          strokeWidth={1.5}
        />
      </button>
      <Card>
        <a
          href="/talks"
          class="text-muted-foreground hover:text-foreground text-sm transition-colors"
        >
          &larr; All Talks
        </a>

        <div class="mt-4">
          <span
            class:list={[
              "inline-block rounded-full px-2.5 py-0.5 text-xs font-medium",
              badgeColors[type] || "event-badge event-badge-activity",
            ]}
          >
            {typeNames[type]}
          </span>

          {
            category && (
              <span class="text-muted-foreground ml-2 text-xs">{category}</span>
            )
          }
        </div>

        <h1
          class="text-foreground mt-3 pr-16 text-xl leading-tight font-bold"
          set:html={title}
        />

        {
          speakers?.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
              {speakers.map((s) => (
                <span class="text-muted-foreground text-sm">
                  {s.name}
                  {s.id && (
                    <>
                      {" · "}
                      <a
                        href={`/profile/${s.id}`}
                        class="text-primary hover:underline"
                      >
                        @{s.id}
                      </a>
                    </>
                  )}
                </span>
              ))}
            </div>
          )
        }

        {
          (dateDisplay || timeDisplay || room) && (
            <div class="text-muted-foreground mt-5 flex flex-col gap-2 text-sm">
              {dateDisplay && (
                <div class="flex items-center gap-2">
                  <span
                    class="text-muted-foreground h-4 w-4 flex-none"
                    set:html={calendarIconSvg}
                  />
                  <span>{dateDisplay}</span>
                </div>
              )}
              {timeDisplay && (
                <div class="flex items-center gap-2">
                  <span
                    class="text-muted-foreground h-4 w-4 flex-none"
                    set:html={clockIconSvg}
                  />
                  <span
                    data-event-time
                    data-start={start || ""}
                    data-end={end || ""}
                  >
                    {timeDisplay}
                  </span>
                </div>
              )}
              {room && (
                <div class="flex items-center gap-2">
                  <span
                    class="text-muted-foreground h-4 w-4 flex-none"
                    set:html={mapPinIconSvg}
                  />
                  <span>{room}</span>
                </div>
              )}
              <div class="flex items-center gap-2">
                <span
                  class="text-muted-foreground h-4 w-4 flex-none"
                  set:html={
                    isRemoteAccessible(mode) ? remoteBadgeSvg : inPersonIconSvg
                  }
                />
                <span>
                  {mode === "hybrid"
                    ? "Available in-person & via livestream"
                    : mode === "remote"
                      ? "Remote only — via livestream"
                      : "In-person only"}
                  {streamTrack && (
                    <>
                      {" — "}
                      {user ? (
                        <a
                          href={`/remote#remote-info`}
                          class="text-primary hover:underline"
                        >
                          Watch on {streamTrack.name} →
                        </a>
                      ) : (
                        <span>
                          {streamTrack.name} ({streamTrack.room})
                        </span>
                      )}
                    </>
                  )}
                </span>
              </div>
            </div>
          )
        }

        {
          description && (
            <p class="text-muted-foreground mt-5 text-sm leading-relaxed whitespace-pre-line">
              {description}
            </p>
          )
        }
      </Card>
    </div>
  </div>
</Layout>

<style>
  .event-card-wrap {
    position: relative;
  }

  .bookmark-ribbon {
    position: absolute;
    top: -0.4rem;
    right: 2.5rem;
    z-index: 10;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 2.6rem;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--theme-muted, #6b7280);
    font-size: 2.6rem;
    line-height: 1;
    cursor: pointer;
    transition: color 150ms ease;
  }

  .bookmark-ribbon:hover {
    color: var(--theme-accent);
  }

  .bookmark-ribbon.is-starred {
    color: var(--primary);
    border-color: var(--header-logo-accent);
  }

  .bookmark-ribbon :global(.bookmark-icon) {
    width: 1em;
    height: 1em;
    filter: drop-shadow(
      0 2px 4px color-mix(in oklch, var(--foreground), transparent 80%)
    );
    transform-origin: top center;
    transition: transform 150ms ease;
  }

  .bookmark-ribbon:not(.is-starred):hover :global(.bookmark-icon-empty) {
    transform: scaleY(1.06);
  }

  .bookmark-ribbon :global(.bookmark-icon-filled) {
    display: none;
  }

  .bookmark-ribbon.is-starred :global(.bookmark-icon-empty) {
    display: none;
  }

  .bookmark-ribbon.is-starred :global(.bookmark-icon-filled) {
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .bookmark-ribbon {
      transition: none;
    }
  }
</style>

<script>
  import { applyStarredState, initStarredHandlers } from "@/scripts/starred";
  applyStarredState();
  initStarredHandlers();

  // Show local time if user is in a different timezone than the conference
  const CONF_TZ = "America/Vancouver";
  const localTz = Intl.DateTimeFormat().resolvedOptions().timeZone;

  // Compare actual offsets — America/Los_Angeles and America/Vancouver are both PT
  function getOffset(tz: string, date: Date): number {
    const str = date.toLocaleString("en-US", { timeZone: tz });
    return date.getTime() - new Date(str).getTime();
  }
  const now = new Date();
  const sameOffset = getOffset(localTz, now) === getOffset(CONF_TZ, now);

  if (!sameOffset) {
    const fmt = (iso: string) =>
      new Intl.DateTimeFormat("en-US", {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
        timeZone: localTz,
      }).format(new Date(iso));

    const shortTz = new Intl.DateTimeFormat("en-US", {
      timeZone: localTz,
      timeZoneName: "short",
    })
      .formatToParts(new Date())
      .find((p) => p.type === "timeZoneName")?.value ?? localTz;

    document.querySelectorAll<HTMLElement>("[data-event-time]").forEach((el) => {
      const start = el.dataset.start;
      const end = el.dataset.end;
      if (!start) return;

      const localDisplay = end
        ? `${fmt(start)} – ${fmt(end)} ${shortTz}`
        : `${fmt(start)} ${shortTz}`;

      const localSpan = document.createElement("span");
      localSpan.className = "text-foreground/70 block text-xs mt-0.5";
      localSpan.textContent = localDisplay;
      el.appendChild(localSpan);
    });
  }
</script>
