---
import "../styles/global.css";
import Header from "../components/shared/Header.astro";
import {
  CLIENT_THEMES,
  THEME_STORAGE_KEY,
  THEME_SESSION_KEY,
  detectClientTheme,
} from "@/components/profile/client-themes";

interface Props {
  title?: string;
  flush?: boolean;
  defaultTheme?: string;
  ogImage?: string;
  page?: string;
}

const {
  title = "ATmosphereConf • Global ATProto Community Conference • Vancouver, Canada, March 26th - 29th, 2026",
  flush = false,
  defaultTheme: defaultThemeProp,
  ogImage = "https://atmosphereconf.org/blue-goose-og.png",
  page,
} = Astro.props;

// Priority: page-level default (e.g. profile handle) > logged-in user's handle > bluesky
const viewerHandle = Astro.locals.loggedInUser?.handle;
const viewerTheme = viewerHandle ? detectClientTheme(viewerHandle) : undefined;
const defaultTheme =
  defaultThemeProp ?? (viewerTheme !== "bluesky" ? viewerTheme : undefined);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-@.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon-@.png" sizes="512x512" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:title" content="ATmosphereConf 2026" />
    <meta
      property="og:description"
      content="ATmosphereConf is the global atproto community conference. Join us in Vancouver, Canada, March 26th - 29th, 2026."
    />
    <meta name="generator" content={Astro.generator} />
    <script
      is:inline
      define:vars={{
        defaultTheme,
        themes: CLIENT_THEMES,
        themeStorageKey: THEME_STORAGE_KEY,
        sessionThemeKey: THEME_SESSION_KEY,
      }}
    >
      (function () {
        const validThemes = new Set(themes);

        const getInitialTheme = () => {
          const urlTheme = new URLSearchParams(window.location.search).get(
            "theme",
          );
          if (validThemes.has(urlTheme)) {
            sessionStorage.setItem(sessionThemeKey, urlTheme);
            return urlTheme;
          }

          const sessionTheme = sessionStorage.getItem(sessionThemeKey);
          if (validThemes.has(sessionTheme)) return sessionTheme;

          const storedTheme = localStorage.getItem(themeStorageKey);
          if (validThemes.has(storedTheme)) return storedTheme;

          return validThemes.has(defaultTheme) ? defaultTheme : null;
        };

        const initialTheme = getInitialTheme();
        if (initialTheme) {
          document.documentElement.dataset.theme = initialTheme;
        }
      })();
    </script>
    <script is:inline>
      (function () {
        // Manual scroll restoration: the default "auto" fires before
        // lazy-loaded schedule content has rendered, so the page is
        // too short and the browser scrolls to the wrong spot.
        if ("scrollRestoration" in history) {
          history.scrollRestoration = "manual";
        }
        var SCROLL_KEY = "atm:scrollY:";
        var key = SCROLL_KEY + location.pathname;

        // Save scroll position before leaving
        window.addEventListener("pagehide", function () {
          try { sessionStorage.setItem(key, String(window.scrollY)); } catch {}
        });

        // Restore after content settles (lazy schedule loads)
        var nav = performance.getEntriesByType("navigation")[0];
        if (nav && nav.type === "back_forward") {
          var saved = null;
          try { saved = sessionStorage.getItem(key); } catch {}
          if (saved != null) {
            var y = Number(saved);
            // Wait for lazy content to load before restoring
            function tryRestore(attempts) {
              if (document.documentElement.scrollHeight >= y + window.innerHeight * 0.5 || attempts <= 0) {
                window.scrollTo(0, y);
              } else {
                requestAnimationFrame(function () { tryRestore(attempts - 1); });
              }
            }
            // Start trying after DOM is ready
            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", function () {
                requestAnimationFrame(function () { tryRestore(30); });
              });
            } else {
              requestAnimationFrame(function () { tryRestore(30); });
            }
          }
        }
      })();
    </script>
    <script is:inline>
      (function () {
        function getLocalDateOptions(formatName) {
          if (formatName === "news") {
            return { month: "short", day: "numeric", year: "numeric" };
          }

          return { month: "short", day: "numeric", year: "numeric" };
        }

        function localizeDates() {
          var nodes = document.querySelectorAll("time[data-local-date]");
          for (var i = 0; i < nodes.length; i++) {
            var node = nodes[i];
            var value = node.getAttribute("datetime");
            if (!value) continue;

            var date = new Date(value);
            if (Number.isNaN(date.getTime())) continue;

            var formatName = node.getAttribute("data-local-date-format") || "";
            node.textContent = new Intl.DateTimeFormat(
              "en-US",
              getLocalDateOptions(formatName),
            ).format(date);
          }
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", localizeDates, {
            once: true,
          });
        } else {
          localizeDates();
        }
      })();
    </script>
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
    <!-- <ViewTransitions /> -->
  </head>
  <body class="bg-background h-full overflow-x-hidden antialiased">
    <div class="flex min-h-screen flex-col">
      <Header transition:animate="none" />
      <main
        class={`mx-auto flex w-full max-w-4xl flex-1 flex-col px-2 sm:px-10 ${flush ? "" : "mb-10"}`}
        {...page ? { "data-page": page } : {}}
      >
        <slot />
      </main>
    </div>
  </body>
</html>
