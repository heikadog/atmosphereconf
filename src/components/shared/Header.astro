---
import Button from "@/components/ui/button.astro";
import { Avatar } from "@/components/profile/Avatar";
import { loadProfile } from "@/lib/profile";
import GoodStuff from "@/assets/goodstuff-goose.png";
import { Image } from "astro:assets";
import HeaderTicket from "./HeaderTicket.astro";

const { loggedInUser } = Astro.locals;
const profile = loggedInUser ? await loadProfile(loggedInUser.did) : null;

const isHome = Astro.url.pathname === "/";
const navLinks = [
  { href: "/#schedule", label: "schedule" },
  { href: "/#tickets", label: "tickets" },
  { href: "/#feed", label: "feed" },
  { href: "/faqs", label: "faqs" },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 h-14"
  style="font-family: var(--font-ui);"
  style="background: var(--header-bg, var(--primary));"
>
  <div
    class="relative z-10 flex h-full items-center"
    style="background: var(--header-bg, var(--primary)); border-bottom: 1px solid var(--header-border, white);"
  >
    <div
      class="mx-auto flex h-full w-full max-w-5xl items-center justify-between px-3 text-base min-[765px]:justify-center min-[765px]:gap-3 min-[765px]:px-4 min-[850px]:gap-6"
    >
      <a
        id="site-logo"
        href="/"
        data-astro-reload
        class="flex items-center gap-1.5 text-lg font-semibold opacity-80 min-[765px]:min-w-0 min-[765px]:flex-1"
        style="color: var(--header-fg, oklch(0.985 0 0));"
      >
        <Image
          id="header-goose"
          class="-ml-7 h-6 w-6 rounded-full object-cover object-top opacity-0 transition-all duration-300"
          src={GoodStuff}
          width={48}
          height={48}
          alt=""
        />
        <span
          ><span
            style="color: var(--header-logo-accent, oklch(0.282 0.091 267.94));"
            >AT</span
          >mosphereConf</span
        >
      </a>
      <nav class="flex items-center gap-4">
        <span
          class="hidden select-none min-[385px]:inline"
          style="color: var(--header-fg-muted, rgba(255,255,255,0.3));"
          aria-hidden="true">//</span
        >
        <!-- desktop links -->
        <div class="hidden items-center gap-4 min-[765px]:flex">
          {
            navLinks.map(({ href, label }) => (
              <a
                href={href}
                data-nav-section={href.replace("/#", "")}
                class="nav-link transition-colors"
                style="color: var(--header-fg-muted, rgba(255,255,255,0.6));"
              >
                {label}
                {href.includes("#") ? (
                  <svg
                    class:list={[
                      "ml-0.5 inline h-2.5 w-2.5 opacity-50",
                      !isHome && "invisible",
                    ]}
                    viewBox="0 0 12 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M6 2v8M2 7l4 4 4-4" />
                  </svg>
                ) : (
                  ""
                )}
              </a>
            ))
          }
        </div>
        <!-- mobile dropdown -->
        <div class="relative min-[765px]:hidden">
          <button
            id="nav-menu-btn"
            class="flex items-center gap-1 transition-colors"
            style="color: var(--header-fg-muted, rgba(255,255,255,0.6));"
            aria-expanded="false"
            aria-haspopup="true"
          >
            menu
            <svg
              class="h-3 w-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            id="nav-menu"
            class="absolute top-full right-0 mt-1 flex hidden w-max min-w-[50vw] flex-col rounded border py-2"
            style="background: var(--header-bg, var(--primary)); border-color: var(--header-border, rgba(255,255,255,0.2));"
          >
            {
              navLinks.map(({ href, label }) => (
                <a
                  href={href}
                  data-nav-section={href.replace("/#", "")}
                  class="nav-link px-4 py-2 transition-colors"
                  style="color: var(--header-fg-muted, rgba(255,255,255,0.6));"
                >
                  {label}
                  {href.includes("#") ? (
                    <svg
                      class:list={[
                        "ml-0.5 inline h-2.5 w-2.5 opacity-50",
                        !isHome && "invisible",
                      ]}
                      viewBox="0 0 12 12"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M6 2v8M2 7l4 4 4-4" />
                    </svg>
                  ) : (
                    ""
                  )}
                </a>
              ))
            }
            <div
              class="mt-2 flex items-center gap-3 border-t px-4 pt-2 min-[450px]:hidden"
              style="border-color: var(--header-border, rgba(255,255,255,0.2));"
            >
              <a
                href="https://github.com/ATProtocol-Community/atmosphereconf"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center transition-colors"
                style="color: var(--header-fg-muted, rgba(255,255,255,0.6));"
                aria-label="GitHub repository"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  ></path>
                </svg>
              </a>
              <button
                id="theme-toggle-mobile"
                class="flex items-center gap-1.5 text-xs transition-colors"
                style="color: var(--header-fg-muted, rgba(255,255,255,0.6));"
                aria-label="Toggle theme"
              >
                <svg
                  class="h-3.5 w-3.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  viewBox="0 0 24 24"
                >
                  <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"
                  ></circle>
                  <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"
                  ></circle>
                  <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle>
                  <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"
                  ></circle>
                  <path
                    d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"
                  ></path>
                </svg>
                <span id="theme-next-label-mobile"></span>
              </button>
            </div>
          </div>
        </div>
      </nav>
      <span
        class="hidden select-none min-[765px]:inline"
        style="color: var(--header-fg-muted, rgba(255,255,255,0.3));"
        aria-hidden="true">//</span
      >
      <div
        class="flex h-8 items-center gap-2 min-[765px]:min-w-0 min-[765px]:flex-1 min-[765px]:justify-end min-[765px]:gap-4"
      >
        <a
          href="https://github.com/ATProtocol-Community/atmosphereconf"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden items-center transition-colors min-[450px]:flex"
          style="color: var(--header-fg-muted, rgba(255,255,255,0.6));"
          aria-label="GitHub repository"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
          </svg>
        </a>
        <button
          id="theme-toggle"
          class="hidden h-7 items-center gap-0 rounded-full px-1.5 text-xs transition-colors min-[450px]:flex min-[850px]:gap-1.5 min-[850px]:border min-[850px]:px-2.5"
          style="color: var(--header-fg-muted, rgba(255,255,255,0.6)); border-color: var(--header-fg-muted, rgba(255,255,255,0.3));"
          aria-label="Toggle theme"
        >
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            viewBox="0 0 24 24"
          >
            <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle>
            <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle>
            <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle>
            <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle>
            <path
              d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"
            ></path>
          </svg>
          <span
            id="theme-next-label"
            class="hidden w-[7ch] truncate min-[850px]:inline"></span>
        </button>
        {
          profile ? (
            <a href={`/profile/${profile.handle}`}>
              <Avatar
                size="sm"
                className="cursor-pointer ring-2 ring-white/50 hover:ring-white"
                src={profile.avatarUrl}
                alt={profile.displayName}
              />
            </a>
          ) : (
            <a
              href="/login"
              class="w-[5.7rem] shrink-0 rounded border px-3 py-1 text-center text-base font-medium whitespace-nowrap transition-colors"
              style="color: var(--header-fg, white); border-color: var(--header-fg-muted, rgba(255,255,255,0.4));"
            >
              sign in
            </a>
          )
        }
      </div>
    </div>
  </div>

  <HeaderTicket />
</header>

<script>
  // Mobile nav dropdown
  const navMenuBtn = document.getElementById("nav-menu-btn");
  const navMenu = document.getElementById("nav-menu");
  if (navMenuBtn && navMenu) {
    navMenuBtn.addEventListener("click", () => {
      const open = navMenu.classList.toggle("hidden");
      navMenuBtn.setAttribute("aria-expanded", String(!open));
    });
    document.addEventListener("click", (e) => {
      if (
        !navMenuBtn.contains(e.target as Node) &&
        !navMenu.contains(e.target as Node)
      ) {
        navMenu.classList.add("hidden");
        navMenuBtn.setAttribute("aria-expanded", "false");
      }
    });
    navMenu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        navMenu.classList.add("hidden");
        navMenuBtn.setAttribute("aria-expanded", "false");
      });
    });
  }

  // On index page, logo scrolls to top instead of reloading
  const logo = document.getElementById("site-logo");
  if (logo && window.location.pathname === "/") {
    logo.addEventListener("click", (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
      history.replaceState(null, "", "/");
    });
  }

  const goose = document.getElementById("header-goose");
  const hero = document.querySelector("[data-hero-goose]");
  if (goose && hero) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          goose.classList.add("opacity-0", "-ml-7");
          goose.classList.remove("opacity-100", "ml-0");
        } else {
          goose.classList.remove("opacity-0", "-ml-7");
          goose.classList.add("opacity-100", "ml-0");
        }
      },
      { threshold: 0 },
    );
    observer.observe(hero);
  }

  // Highlight nav link for the section currently in view
  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-section]");
  const sections = new Map<string, Element>();
  navLinks.forEach((link) => {
    const id = link.dataset.navSection!;
    const el = document.getElementById(id);
    if (el) sections.set(id, el);
  });

  const active = "nav-active underline decoration-dashed underline-offset-4";
  const inactive = "";

  function setActive(id: string | null) {
    navLinks.forEach((link) => {
      const isActive = link.dataset.navSection === id;
      active
        .split(" ")
        .filter(Boolean)
        .forEach((c) => link.classList.toggle(c, isActive));
      inactive
        .split(" ")
        .filter(Boolean)
        .forEach((c) => link.classList.toggle(c, !isActive));
    });
  }

  let currentActive: string | null = null;
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          currentActive = entry.target.id;
          setActive(currentActive);
          return;
        }
        // Clear if the currently active section left the viewport
        if (entry.target.id === currentActive) {
          currentActive = null;
          setActive(null);
        }
      }
    },
    { rootMargin: "-50% 0px -50% 0px" },
  );

  sections.forEach((el) => sectionObserver.observe(el));

  // Activate "tickets" nav when the header ticket banner appears
  window.addEventListener("ticket-banner", ((e: CustomEvent) => {
    if (e.detail.visible && !currentActive) {
      setActive("tickets");
    } else if (!e.detail.visible && currentActive === null) {
      setActive(null);
    }
  }) as EventListener);

  // Set initial active from URL hash
  const hash = window.location.hash.replace("#", "");
  if (hash && sections.has(hash)) setActive(hash);

  // Theme toggle
  const THEMES = [
    "bluesky",
    "blacksky",
    "reddwarf",
    "pckt",
    "germ",
    "northsky",
    "plyr.fm",
    "semble",
    "spark",
    "ngerakines",
    "kandake",
  ];
  const themeLabel = document.getElementById("theme-next-label");
  const themeLabelMobile = document.getElementById("theme-next-label-mobile");

  function syncThemeLabel() {
    const current =
      document.documentElement.getAttribute("data-theme") || "bluesky";
    if (themeLabel) themeLabel.textContent = current;
    if (themeLabelMobile) themeLabelMobile.textContent = current;
  }
  syncThemeLabel();

  function cycleTheme() {
    const current =
      document.documentElement.getAttribute("data-theme") || "bluesky";
    const next = THEMES[(THEMES.indexOf(current) + 1) % THEMES.length];
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("atmosphereconf:theme", next);
    syncThemeLabel();
  }

  document
    .getElementById("theme-toggle")
    ?.addEventListener("click", cycleTheme);
  document
    .getElementById("theme-toggle-mobile")
    ?.addEventListener("click", cycleTheme);
</script>

<style>
  .nav-link:hover {
    color: var(--header-fg, white);
  }
  .nav-active {
    color: var(--header-fg, white);
    text-decoration-color: var(--header-fg-muted, rgba(255, 255, 255, 0.7));
  }
  #theme-toggle:hover,
  a[aria-label="GitHub repository"]:hover {
    color: var(--header-fg, white);
  }
</style>
