---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  sponsor: CollectionEntry<"sponsors">;
}

const { sponsor } = Astro.props;
const { name, logo, url } = sponsor.data;
---

<a
  href={url !== "TBD" ? url : undefined}
  target={url !== "TBD" ? "_blank" : undefined}
  rel={url !== "TBD" ? "noopener noreferrer" : undefined}
  class:list={[
    "border-border bg-card flex flex-col items-center justify-center gap-3 rounded-[var(--paper-radius-sm)] border p-6 transition-[transform,box-shadow] duration-[160ms] ease-out motion-reduce:transition-none",
    url !== "TBD" &&
      "hover:-translate-y-0.5 hover:shadow-[var(--paper-shadow)] active:translate-y-0 active:duration-[60ms]",
  ]}
>
  <Image src={logo} alt={name} class="h-12 w-auto max-w-full object-contain" />
  <span class="text-muted-foreground text-sm font-medium">{name}</span>
</a>
