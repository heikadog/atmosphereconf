---
const RELEASE_IDS = {
  live: "cfllygt-phg,corporate-supporter",
  remote: "remote-attendee",
} as const;

interface Props {
  type: keyof typeof RELEASE_IDS;
  class?: string;
}

const { type, class: className } = Astro.props;
---

<tito-widget
  id={`tito-${type}`}
  class:list={[className]}
  data-ticket-type={type}
  event="atmosphereconf/atmosphereconf2026"
  releases={RELEASE_IDS[type]}></tito-widget>

{
  import.meta.env.DEV ? (
    <script
      is:inline
      src="https://js.tito.io/v2/with/inline,development_mode"
      async
    />
  ) : (
    <script is:inline src="https://js.tito.io/v2/with/inline" async />
  )
}

<style is:global>
  /* ── Reset Tito defaults ── */
  tito-widget > * {
    margin: 0 !important;
  }

  /* ── Form container ── */
  tito-widget .tito-widget-form {
    background: transparent !important;
    color: var(--foreground) !important;
    border: var(--card-border-width, 1px) var(--card-border-style, solid)
      var(--border) !important;
    border-radius: var(--card-radius) !important;
    padding: 1.25rem !important;
  }

  /* ── Release card ── */
  tito-widget .tito-release {
    border: none !important;
    border-radius: var(--radius-lg, 0.75rem) !important;
    background: var(--card) !important;
    padding: 1.25rem 1.5rem !important;
    margin-bottom: 0.75rem !important;
    box-shadow: none !important;
  }

  /* ── Ticket name ── */
  tito-widget .tito-release--title,
  tito-widget label {
    font-family: var(--font-ui) !important;
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: var(--primary) !important;
  }

  /* ── Price ── */
  tito-widget .tito-price,
  tito-widget .tito-price-details-regular {
    font-family: var(--font-ui) !important;
    font-weight: 600 !important;
    color: var(--primary) !important;
  }

  tito-widget .tito-price-details-donation input {
    min-width: 80px !important;
  }

  /* ── Description text ── */
  tito-widget .tito-release-description,
  tito-widget .tito-release-description--description,
  tito-widget .tito-release-description p,
  tito-widget .tito-release-description li {
    font-size: 0.85rem !important;
    color: var(--foreground) !important;
    opacity: 0.75 !important;
    line-height: 1.6 !important;
  }

  /* ── Quantity input ── */
  tito-widget .tito-quantity-input,
  tito-widget input[type="number"] {
    width: 3.5rem !important;
    text-align: center !important;
    border-radius: var(--radius-sm, 0.375rem) !important;
    border: var(--card-border-width, 1px) var(--card-border-style, solid)
      var(--border) !important;
    background: var(--card) !important;
    color: var(--foreground) !important;
    font-family: var(--font-ui) !important;
    font-size: 0.875rem !important;
    padding: 0.35rem 0.25rem !important;
    box-shadow: none !important;
    transition:
      border-color 0.15s,
      box-shadow 0.15s !important;
  }

  /* ── Quantity +/- links ── */
  tito-widget .tito-release--increment-quantity--link,
  tito-widget .tito-release--decrement-quantity--link {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: transparent !important;
    color: var(--primary) !important;
    border: none !important;
    border-radius: 0 !important;
    font-family: var(--font-ui) !important;
    transition: opacity 0.15s !important;
  }

  tito-widget .tito-release--increment-quantity--link:hover,
  tito-widget .tito-release--decrement-quantity--link:hover {
    opacity: 0.7 !important;
  }

  tito-widget .tito-release--decrement-quantity--link--disabled {
    opacity: 0.3 !important;
    cursor: not-allowed !important;
    pointer-events: none !important;
  }

  /* ── Quantity row spacing ── */
  tito-widget .tito-release--quantity {
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
  }

  /* ── Submit / Continue button ── */
  tito-widget .tito-submit {
    background: var(--primary) !important;
    color: var(--primary-foreground) !important;
    font-family: var(--font-ui) !important;
    font-size: 0.8rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    border: none !important;
    border-radius: var(--radius-md, 0.5rem) !important;
    padding: 0.65rem 1.5rem !important;
    cursor: pointer !important;
    box-shadow: none !important;
    transition: opacity 0.15s !important;
  }

  tito-widget .tito-submit:hover {
    opacity: 0.9 !important;
  }

  /* ── Discount code ── */
  tito-widget .tito-discount-code-field,
  tito-widget input[type="text"] {
    border-radius: var(--radius-sm, 0.375rem) !important;
    border: var(--card-border-width, 1px) dashed var(--primary) !important;
    background: var(--card) !important;
    padding: 0.5rem 0.75rem !important;
    font-size: 0.875rem !important;
    color: var(--foreground) !important;
    font-family: var(--font-ui) !important;
    box-shadow: none !important;
    transition:
      border-color 0.15s,
      box-shadow 0.15s !important;
  }

  tito-widget .tito-submit--discount-code {
    border-radius: var(--radius-sm, 0.375rem) !important;
    border: var(--card-border-width, 1px) var(--card-border-style, solid)
      var(--border) !important;
    background: var(--card) !important;
    color: var(--foreground) !important;
    font-size: 0.8rem !important;
    font-weight: 600 !important;
    padding: 0.5rem 1rem !important;
    cursor: pointer !important;
    box-shadow: none !important;
    transition: border-color 0.15s !important;
  }

  /* ── Focus states ── */
  tito-widget .tito-submit:focus-visible,
  tito-widget .tito-submit--discount-code:focus-visible {
    outline: 2px solid var(--ring) !important;
    outline-offset: 2px !important;
  }

  tito-widget input:focus-visible,
  tito-widget select:focus-visible,
  tito-widget textarea:focus-visible {
    border-color: var(--ring) !important;
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--ring), transparent 50%) !important;
    outline: none !important;
  }

  tito-widget .tito-release--increment-quantity--link:focus-visible,
  tito-widget .tito-release--decrement-quantity--link:focus-visible {
    outline: 2px solid var(--ring) !important;
    outline-offset: 2px !important;
  }

  /* ── Form actions row ── */
  tito-widget .tito-form-actions {
    display: flex !important;
    align-items: center !important;
    gap: 0.75rem !important;
    margin-top: 1rem !important;
    padding-top: 1rem !important;
    border-top: 1px solid color-mix(in oklch, var(--primary), transparent 75%) !important;
  }

  /* ── Kill all other Tito borders/dividers ── */
  tito-widget * {
    border-color: var(--border) !important;
  }

  /* ── Blue-tinted internal dividers (not inputs/form border) ── */
  tito-widget .tito-release-description,
  tito-widget .tito-release--footer {
    border-color: color-mix(
      in oklch,
      var(--primary),
      transparent 75%
    ) !important;
  }

  /* ── Currency symbol and misc text ── */
  tito-widget .tito-price-details-donation,
  tito-widget .tito-release--quantity,
  tito-widget .tito-release--footer {
    color: var(--primary) !important;
  }

  /* ── Misc cleanup ── */
  tito-widget .tito-release--tax {
    font-size: 0.75rem !important;
    color: var(--muted-foreground) !important;
    font-family: var(--font-ui) !important;
  }

  tito-widget .tito-release--status {
    font-size: 0.7rem !important;
    font-family: var(--font-ui) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: var(--muted-foreground) !important;
  }

  /* ── All Tito inputs and selects ── */
  tito-widget input,
  tito-widget select,
  tito-widget textarea {
    background: var(--card) !important;
    color: var(--foreground) !important;
    border-color: var(--border) !important;
  }

  /* ── Reserve space before Tito loads to prevent layout shift ── */
  tito-widget:not(.tito-widget-loaded) {
    display: block;
  }
  tito-widget[data-ticket-type="live"]:not(.tito-widget-loaded) {
    aspect-ratio: 718 / 686;
  }
  tito-widget[data-ticket-type="remote"]:not(.tito-widget-loaded) {
    aspect-ratio: 718 / 364;
  }
</style>

<script>
  // Re-scroll to hash anchor after Tito loads, but only if the user
  // hasn't interacted (scrolled, clicked, etc.) since page load.
  (() => {
    let userInteracted = false;
    const markInteracted = () => {
      userInteracted = true;
    };
    const events = ["scroll", "click", "touchstart", "keydown"] as const;
    events.forEach((e) =>
      window.addEventListener(e, markInteracted, { once: true, passive: true }),
    );

    const observer = new MutationObserver(() => {
      const loaded = document.querySelector("tito-widget .tito-widget-form");
      if (!loaded) return;
      observer.disconnect();

      // Mark widget as loaded (removes min-height)
      document
        .querySelectorAll("tito-widget")
        .forEach((el) => el.classList.add("tito-widget-loaded"));

      if (!userInteracted && window.location.hash) {
        const target = document.querySelector(window.location.hash);
        target?.scrollIntoView({ behavior: "smooth" });
      }

      events.forEach((e) => window.removeEventListener(e, markInteracted));
    });

    observer.observe(document.body, { childList: true, subtree: true });
  })();
</script>
