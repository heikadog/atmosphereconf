---
interface Props {
  maxWidth?: string;
  class?: string;
  id?: string;
}

const { maxWidth = "76rem", class: className = "", id } = Astro.props;
---

<section
  id={id}
  class:list={["breakout", className]}
  style={`--breakout-max-width: ${maxWidth};`}
>
  <div class="breakout-inner">
    <slot />
  </div>
</section>

<style>
  .breakout {
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    width: 100vw;
    padding: clamp(1.5rem, 3vw, 3rem) 0;
  }

  .breakout-inner {
    width: min(var(--breakout-max-width), calc(100vw - 1.5rem));
    margin: 0 auto;
  }

  @media (max-width: 959px) {
    .breakout {
      padding: 1.25rem 0;
    }

    .breakout-inner {
      width: min(var(--breakout-max-width), calc(100vw - 0.75rem));
    }
  }
</style>
