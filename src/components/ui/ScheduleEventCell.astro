---
import { formatConferenceTime } from "@/lib/datetime";
import BookmarkIcon from "@/components/ui/BookmarkIcon.astro";

interface Speaker {
  name: string;
  id?: string;
}

interface Props {
  event: {
    id?: string;
    title: string;
    type: string;
    mode?: string;
    speakers?: Speaker[];
    start?: string;
    end?: string;
    category?: string;
    description?: string;
  };
}

const { event } = Astro.props;

const linkableTypes = new Set([
  "workshop",
  "presentation",
  "lightning-talk",
  "panel",
]);
const href =
  event.id && linkableTypes.has(event.type) ? `/event/${event.id}` : null;
const isInfo = event.type === "info";

function formatTime(iso: string) {
  return formatConferenceTime(iso).toLowerCase().replace(" ", "");
}

const durationMin =
  event.start && event.end
    ? (new Date(event.end).getTime() - new Date(event.start).getTime()) / 60_000
    : 0;

const time = (() => {
  if (!event.start || durationMin <= 10) return "";
  const s = formatTime(event.start);
  const e = event.end ? formatTime(event.end) : "";
  return e ? `${s} – ${e}` : s;
})();

function getColors(type: string, category?: string) {
  if (category === "Unconference") return "event-badge event-badge-unconference";
  switch (type) {
    case "info":
      return "event-badge event-badge-info";
    case "activity":
      return "event-badge event-badge-activity";
    case "workshop":
      return "event-badge event-badge-workshop";
    case "lightning-talk":
      return "event-badge event-badge-lightning";
    case "panel":
      return "event-badge event-badge-panel";
    default:
      return "event-badge event-badge-presentation";
  }
}

function getSubColors(type: string, category?: string) {
  if (category === "Unconference") return "event-sub-unconference";
  switch (type) {
    case "info":
      return "event-sub-info";
    case "activity":
      return "event-sub-activity";
    case "workshop":
      return "event-sub-workshop";
    case "lightning-talk":
      return "event-sub-lightning";
    case "panel":
      return "event-sub-panel";
    default:
      return "event-sub-presentation";
  }
}

const speakerNames = event.speakers?.map((s) => s.name).join(", ");

function getSizeClass(min: number) {
  switch (true) {
    case min <= 15:
      return "schedule-event-card-tiny";
    case min <= 30:
      return "schedule-event-card-short";
    case min <= 60:
      return "schedule-event-card-medium";
    default:
      return "schedule-event-card-tall";
  }
}

const sizeClass = getSizeClass(durationMin);
const showSpeakers = !isInfo && !!speakerNames && durationMin >= 120;
---

<Fragment>
  {href && <a href={href} class="absolute inset-0 z-10" />}
  <div
    class:list={[
      "schedule-event-card relative z-0 flex h-full min-h-0 flex-1 flex-col overflow-hidden border leading-tight transition-[transform,filter,box-shadow,border-color]",
      getColors(event.type, event.category),
      sizeClass,
      isInfo && "flex flex-col items-center justify-center text-center",
      href && "evt-linkable",
    ]}
    data-type={event.type}
    data-mode={event.mode}
  >
    <p class="schedule-event-title" set:html={event.title} />
    {
      showSpeakers && (
        <p class="schedule-event-speakers" title={speakerNames}>
          {speakerNames}
        </p>
      )
    }
    {
      time && (
        <p class:list={["schedule-event-time", getSubColors(event.type, event.category)]}>
          {time}
        </p>
      )
    }
  </div>
  {
    event.id && href && (
      <button
        class="evt-star-btn absolute z-20"
        data-star-btn={event.id}
        aria-label="Bookmark this session"
        aria-pressed="false"
      >
        <BookmarkIcon class="star-icon star-icon-empty" strokeWidth={1.5} />
        <BookmarkIcon
          class="star-icon star-icon-filled"
          strokeWidth={1.5}
          filled
        />
      </button>
    )
  }
</Fragment>

<style>
  .schedule-event-card {
    min-height: 100%;
    justify-content: flex-start;
    padding: 0.5rem 0.625rem;
    border-radius: 0.85rem;
    font-size: 0.78rem;
    isolation: isolate;
  }

  .schedule-event-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0.9;
    pointer-events: none;
  }

  .schedule-event-title,
  .schedule-event-speakers,
  .schedule-event-time {
    position: relative;
    z-index: 1;
  }

  .schedule-event-title {
    display: -webkit-box;
    overflow: hidden;
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.16;
    text-wrap: balance;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .schedule-event-time {
    padding-top: 0.38rem;
    font-size: 0.69rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .schedule-event-speakers {
    display: -webkit-box;
    margin-top: 0.42rem;
    overflow: hidden;
    color: color-mix(in oklch, currentColor, white 30%);
    font-size: 0.67rem;
    line-height: 1.28;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .schedule-event-card-tiny,
  .schedule-event-card-short {
    border-radius: 0.72rem;
  }

  .schedule-event-card-tiny {
    padding: 0.2rem 0.4rem;
    justify-content: center;
  }

  .schedule-event-card-tiny .schedule-event-title {
    -webkit-line-clamp: 1;
    font-size: 0.66rem;
  }

  .schedule-event-card-tiny .schedule-event-time,
  .schedule-event-card-short .schedule-event-time {
    padding-top: 0.2rem;
    font-size: 0.64rem;
  }

  .schedule-event-card-short .schedule-event-title {
    font-size: 0.76rem;
  }

  /* card-medium inherits the default 2-line clamp from .schedule-event-title */

  .schedule-event-card-tall .schedule-event-title {
    -webkit-line-clamp: 3;
    font-size: 0.84rem;
  }

  .schedule-event-card-tall .schedule-event-time {
    font-size: 0.72rem;
  }

  .schedule-event-card.event-badge-info {
    justify-content: center;
    padding-inline: 1rem;
  }

  .schedule-event-card.event-badge-info .schedule-event-title {
    font-size: 0.82rem;
    font-weight: 620;
  }

  .schedule-event-card.event-badge-info .schedule-event-time {
    margin-top: 0.18rem;
    padding-top: 0;
  }

  :global(.group\/evt:hover) .evt-linkable {
    transform: scale(1.025);
    filter: brightness(1.04) saturate(1.1);
  }

  .evt-star-btn {
    display: none;
    align-items: flex-start;
    justify-content: center;
    position: absolute;
    top: 0.35rem;
    right: 0.65rem;
    width: 1.35rem;
    padding: 0;
    border: none;
    background: transparent;
    color: color-mix(in oklch, var(--foreground), transparent 55%);
    opacity: 0.85;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: color 150ms ease;
  }

  :global(.group\/evt:hover) .evt-star-btn,
  .evt-star-btn.is-starred {
    display: flex;
  }

  @media (hover: none) {
    .evt-star-btn {
      display: flex;
    }
  }

  .evt-star-btn :global(.star-icon) {
    width: 1em;
    height: 1em;
    transform-origin: top center;
    transition: transform 150ms ease;
  }

  :global(.group\/evt:hover)
    .evt-star-btn:not(.is-starred)
    :global(.star-icon-empty) {
    transform: scaleY(1.06);
  }

  .evt-star-btn :global(.star-icon-filled) {
    display: none;
  }

  .evt-star-btn.is-starred :global(.star-icon-empty) {
    display: none;
  }

  .evt-star-btn.is-starred :global(.star-icon-filled) {
    display: block;
  }

  .evt-star-btn.is-starred {
    color: var(--primary);
  }

  .schedule-event-card-tiny ~ .evt-star-btn {
    font-size: 0.7rem;
    width: 0.9rem;
    top: 0.3rem;
    right: 0.65rem;
  }

  .schedule-event-card-short ~ .evt-star-btn {
    font-size: 0.75rem;
    width: 1.05rem;
    top: 0.3rem;
    right: 0.5rem;
  }

  .evt-star-btn:focus-visible {
    outline: 2px solid color-mix(in oklch, var(--primary), transparent 30%);
    outline-offset: 1px;
  }
</style>

<script>
  import { applyStarredState, initStarredHandlers } from "@/scripts/starred";
  applyStarredState();
  initStarredHandlers();
</script>
