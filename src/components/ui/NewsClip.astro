---
import { formatLocalDate } from "@/lib/datetime";

interface Props {
  href: string;
  imageUrl?: string;
  date: string;
  title: string;
  description?: string;
}

const { href, imageUrl, date, title, description } = Astro.props;

function formatDate(dateString: string) {
  return formatLocalDate(dateString, {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="news-clip group"
>
  {
    imageUrl ? (
      <img src={imageUrl} alt="" class="news-clip-image" />
    ) : (
      <div class="news-clip-image news-clip-placeholder">wire</div>
    )
  }
  <div class="min-w-0">
    <time
      datetime={date}
      class="news-clip-date"
      data-local-date
      data-local-date-format="news"
    >
      {formatDate(date)}
    </time>
    <p class="news-clip-title">{title}</p>
    {description && <p class="news-clip-summary">{description}</p>}
  </div>
</a>

<style>
  .news-clip {
    display: grid;
    grid-template-columns: 6rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
    text-decoration: none;
    padding-bottom: 0.85rem;
    border-bottom: 2px dotted var(--primary);
  }

  .news-clip-image {
    width: 100%;
    aspect-ratio: 5 / 4;
    object-fit: cover;
    border-radius: var(--paper-radius-sm);
    border: 1px solid color-mix(in oklch, var(--border), transparent 35%);
    background: var(--muted);
  }

  .news-clip-placeholder {
    display: grid;
    place-items: center;
    color: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .news-clip-date {
    display: inline-block;
    margin-bottom: 0.3rem;
    color: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .news-clip-title {
    color: var(--foreground);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    text-wrap: balance;
    transition: color 180ms ease;
  }

  .group:hover .news-clip-title {
    color: var(--primary);
  }

  .news-clip-summary {
    margin-top: 0.35rem;
    color: var(--muted-foreground);
    font-size: 0.88rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 959px) {
    .news-clip {
      grid-template-columns: 5rem minmax(0, 1fr);
    }
  }
</style>
