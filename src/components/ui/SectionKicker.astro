---
import slugify from "slugify";

interface Props {
  text: string;
  anchor?: boolean;
  href?: string;
  class?: string;
}

const { text, anchor = true, href, class: className = "" } = Astro.props;
const slug = href
  ? href.replace(/^#/, "")
  : anchor
    ? slugify(text, { lower: true, strict: true })
    : undefined;
---

<p id={slug} class:list={["section-kicker", className]}>
  {
    slug ? (
      <a href={`#${slug}`} class="section-kicker-link">
        {`// ${text.toUpperCase()}`}
      </a>
    ) : (
      `// ${text.toUpperCase()}`
    )
  }
</p>

<style>
  .section-kicker {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--primary);
  }

  .section-kicker-link {
    color: inherit;
    text-decoration: none;
  }

  .section-kicker-link:hover {
    text-decoration: underline;
  }
</style>
