---
import ScheduleEventCell from "./ScheduleEventCell.astro";
import { getConferenceDateTimeParts } from "@/lib/datetime";
import { isRemoteAccessible } from "@/lib/calendar-event";
import { linkableTypes } from "@/lib/program";

interface Speaker {
  name: string;
  id?: string;
}

interface ScheduleEvent {
  id?: string;
  title: string;
  type: string;
  mode?: string;
  speakers?: Speaker[];
  start?: string;
  end?: string;
  room?: string;
  category?: string;
  description?: string;
  link_url?: string;
  link_text?: string;
}

interface Props {
  events: ScheduleEvent[];
  rooms: string[];
  remote?: boolean;
  date?: string;
}

const { events, rooms, remote = false, date } = Astro.props;

function isLiveOnly(event: ScheduleEvent) {
  return !isRemoteAccessible(event.mode);
}

// --- Time helpers ---

function isoToMinutes(iso: string): number {
  const parts = getConferenceDateTimeParts(iso);
  if (!parts) return 0;
  return parts.hour * 60 + parts.minute;
}

function formatHour(minutes: number) {
  const h = Math.floor(minutes / 60);
  const p = h >= 12 ? "PM" : "AM";
  const d = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return `${d}${p}`;
}

// --- Grid math ---

const parsed = events
  .filter((e) => e.start)
  .map((e) => {
    const start = isoToMinutes(e.start!);
    const end = e.end ? isoToMinutes(e.end) : start + 30;
    return { ...e, startMin: start, endMin: end };
  });

const SLOT = 5;
const minTime =
  Math.floor(Math.min(...parsed.map((e) => e.startMin)) / SLOT) * SLOT;
const maxTime =
  Math.ceil(Math.max(...parsed.map((e) => e.endMin)) / SLOT) * SLOT;
const totalSlots = (maxTime - minTime) / SLOT;

const isInfo = (type: string) => type === "info";

function isLinkable(event: { id?: string; type: string }) {
  return !!(event.id && linkableTypes.has(event.type));
}

const gridEvents = parsed
  .filter((e) => isInfo(e.type) || rooms.includes(e.room || ""))
  .filter((e) => !/breakfast/i.test(e.title))
  .map((e, i, arr) => {
    const fullWidth = isInfo(e.type);
    return {
      ...e,
      startRow: Math.round((e.startMin - minTime) / SLOT) + 2,
      spanRows: Math.max(1, Math.round((e.endMin - e.startMin) / SLOT)),
      colStart: fullWidth ? 1 : rooms.indexOf(e.room!) + 1,
      colSpan: fullWidth ? rooms.length : 1,
      zIndex: e.startMin,
    };
  });

// Check if an info event overlaps with any other event
function hasInfoOverlap(event: (typeof gridEvents)[0]) {
  if (!isInfo(event.type)) return false;
  return gridEvents.some(
    (other) =>
      other !== event &&
      event.startMin < other.endMin &&
      other.startMin < event.endMin,
  );
}

// Shared time grid template
const timeGridRows = `grid-template-rows: 0.5rem repeat(${totalSlots}, 1rem)`;
---

<div
  class="day-schedule border-border isolate rounded-lg border"
  data-schedule-date={date}
  data-min-time={minTime}
  data-max-time={maxTime}
  data-slot={SLOT}
>
  <!-- ========== MOBILE: Vertical room tabs + single-room panels ========== -->

  <div class="mobile-room-nav divide-border flex flex-col divide-y md:hidden">
    {
      rooms.map((room, i) => (
        <button
          data-room-tab={i}
          class:list={[
            "room-tab px-3 py-2.5 text-left text-xs font-semibold tracking-wide uppercase transition-colors",
            i === 0
              ? "is-active border-l-primary bg-accent/50 text-primary border-l-2"
              : "text-muted-foreground",
          ]}
        >
          {room}
        </button>
      ))
    }
  </div>

  {
    rooms.map((room, roomIndex) => {
      const roomEvents = gridEvents.filter(
        (e) => isInfo(e.type) || e.room === room,
      );
      return (
        <div
          data-room-panel={roomIndex}
          class:list={[
            "border-border border-t md:hidden",
            roomIndex !== 0 && "hidden",
          ]}
        >
          <div class="flex">
            <div class="border-border hidden w-14 flex-none border-r md:block" />
            <div class="grid min-w-0 flex-1 grid-cols-1 grid-rows-1">
              <div
                class="divide-border/40 col-start-1 col-end-2 row-start-1 grid divide-y"
                style={timeGridRows}
              >
                <div class="row-end-1 h-0" />
                <div />
                {Array.from({ length: totalSlots }).map((_, i) => (
                  <div>
                    {(minTime + i * SLOT) % 60 === 0 && (
                      <div class="text-muted-foreground sticky left-0 z-20 -mt-2 -ml-14 hidden w-14 pr-2 text-right text-[0.65rem] leading-none md:block">
                        {formatHour(minTime + i * SLOT)}
                      </div>
                    )}
                  </div>
                ))}
              </div>
              <ol
                class="col-start-1 col-end-2 row-start-1 grid"
                style={`grid-template-columns: minmax(0, 1fr); ${timeGridRows}`}
              >
                {roomEvents.map((event) => (
                  <li
                    class:list={[
                      "relative flex min-h-5 p-[0.22rem]",
                      isLinkable(event) && "group/evt cursor-pointer",
                      hasInfoOverlap(event) && "info-overlap",
                    ]}
                    style={`grid-row: ${event.startRow} / span ${event.spanRows}; grid-column: 1; z-index: ${event.zIndex}`}
                  >
                    <ScheduleEventCell event={event} />
                  </li>
                ))}
              </ol>
              <div class="now-indicator pointer-events-none col-start-1 col-end-2 row-start-1 relative" aria-hidden="true">
                <div class="now-line absolute inset-x-0 flex items-center hidden" style="z-index: 2000">
                  <div class="size-2.5 rounded-full bg-primary shrink-0"></div>
                  <div class="h-0.5 flex-1 bg-primary"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      );
    })
  }

  <!-- ========== DESKTOP: Full multi-column layout ========== -->
  <div class="hidden md:block">
    <div>
      <div class="desktop-room-header border-border flex rounded-t-lg border-b">
        <div class="border-border w-14 flex-none border-r"></div>
        <div
          class="divide-border grid flex-auto divide-x"
          style={`grid-template-columns: repeat(${rooms.length}, minmax(0, 1fr))`}
        >
          {
            rooms.map((room) => (
              <div class="text-muted-foreground px-2 py-2.5 text-center text-xs font-semibold tracking-wide uppercase">
                {room}
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex">
        <div class="border-border w-14 flex-none border-r"></div>
        <div class="grid flex-auto grid-cols-1 grid-rows-1">
          <div
            class="divide-border/40 col-start-1 col-end-2 row-start-1 grid divide-y"
            style={timeGridRows}
          >
            <div></div>
            {
              Array.from({ length: totalSlots }).map((_, i) => (
                <div>
                  {(minTime + i * SLOT) % 60 === 0 && (
                    <div class="text-muted-foreground sticky left-0 z-20 -mt-2 -ml-14 w-14 pr-2 text-right text-[0.65rem] leading-none">
                      {formatHour(minTime + i * SLOT)}
                    </div>
                  )}
                </div>
              ))
            }
          </div>

          <div
            class="divide-border/40 col-start-1 col-end-2 row-start-1 grid grid-rows-1 divide-x"
            style={`grid-template-columns: repeat(${rooms.length}, minmax(0, 1fr))`}
          >
            {rooms.map(() => <div class="row-span-full" />)}
          </div>

          <ol
            class="col-start-1 col-end-2 row-start-1 grid"
            style={`grid-template-columns: repeat(${rooms.length}, minmax(0, 1fr)); ${timeGridRows}`}
          >
            {
              gridEvents.map((event) => (
                <li
                  class:list={[
                    "relative flex min-h-5 p-[0.22rem]",
                    isLinkable(event) && "group/evt cursor-pointer",
                    remote && isLiveOnly(event) && "live-only",
                    hasInfoOverlap(event) && "info-overlap",
                  ]}
                  data-mode={event.mode}
                  style={`grid-row: ${event.startRow} / span ${event.spanRows}; grid-column: ${event.colStart} / span ${event.colSpan}; z-index: ${event.zIndex}`}
                >
                  <ScheduleEventCell event={event} />
                </li>
              ))
            }
          </ol>
          <div class="now-indicator pointer-events-none col-start-1 col-end-2 row-start-1 relative" aria-hidden="true">
            <div class="now-line absolute inset-x-0 flex items-center hidden" style="z-index: 2000">
              <div class="size-2.5 rounded-full bg-primary shrink-0"></div>
              <div class="h-0.5 flex-1 bg-primary"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .day-schedule {
    overflow-x: clip;
    overflow-y: visible;
    --schedule-sticky-top: 3.5rem;
    --schedule-sticky-top-mobile: 6rem;
  }

  .mobile-room-nav,
  .desktop-room-header {
    position: sticky;
    z-index: 1500;
    background: var(--card);
  }

  .mobile-room-nav {
    top: var(--schedule-sticky-top-mobile);
  }

  .desktop-room-header {
    top: var(--schedule-sticky-top);
  }

  @media (min-width: 640px) {
    .mobile-room-nav {
      top: var(--schedule-sticky-top);
    }
  }
</style>

<script>
  document.querySelectorAll(".day-schedule").forEach((schedule) => {
    const tabs = schedule.querySelectorAll<HTMLElement>("[data-room-tab]");
    const panels = schedule.querySelectorAll<HTMLElement>("[data-room-panel]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const idx = tab.dataset.roomTab;

        tabs.forEach((t) => {
          const isActive = t === tab;
          t.classList.toggle("is-active", isActive);
          t.classList.toggle("border-l-2", isActive);
          t.classList.toggle("border-l-primary", isActive);
          t.classList.toggle("text-primary", isActive);
          t.classList.toggle("bg-accent/50", isActive);
          t.classList.toggle("text-muted-foreground", !isActive);
        });

        panels.forEach((p) => {
          p.classList.toggle("hidden", p.dataset.roomPanel !== idx);
        });
      });
    });
  });

  // --- Now indicator ---
  const CONF_TZ = "America/Vancouver";

  function getConfNow() {
    const parts = new Intl.DateTimeFormat("en-US", {
      timeZone: CONF_TZ,
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    }).formatToParts(new Date());
    const g = (t: string) =>
      parseInt(parts.find((p) => p.type === t)?.value ?? "0");
    return {
      date: `${g("year")}-${String(g("month")).padStart(2, "0")}-${String(g("day")).padStart(2, "0")}`,
      mins: g("hour") * 60 + g("minute"),
    };
  }

  function updateNowLines() {
    const { date, mins } = getConfNow();
    document
      .querySelectorAll<HTMLElement>(".day-schedule[data-schedule-date]")
      .forEach((el) => {
        const d = el.dataset.scheduleDate!;
        const min = Number(el.dataset.minTime);
        const max = Number(el.dataset.maxTime);
        const slot = Number(el.dataset.slot);
        const lines = el.querySelectorAll<HTMLElement>(".now-line");

        if (d !== date || mins < min || mins > max) {
          lines.forEach((l) => l.classList.add("hidden"));
          return;
        }

        const top = `calc(0.5rem + ${(mins - min) / slot}rem)`;
        lines.forEach((l) => {
          l.style.top = top;
          l.classList.remove("hidden");
        });
      });
  }

  updateNowLines();
  setInterval(updateNowLines, 60_000);
  document.addEventListener("schedule:loaded", updateNowLines);
</script>
