---
import CardMeta from "@/components/ui/CardMeta.astro";
import remoteBadgeSvg from "@/components/ui/icons/RemoteBadge.svg?raw";
import BookmarkIcon from "@/components/ui/BookmarkIcon.astro";
import { formatConferenceDate } from "@/lib/datetime";
import { isRemoteAccessible, type EventMode } from "@/lib/calendar-event";

interface Speaker {
  name: string;
  id?: string;
}

interface Props {
  talkId: string;
  title: string;
  speakers?: Speaker[];
  typeName: string;
  mode?: EventMode;
  start?: string;
  description?: string;
  anchor?: boolean;
  class?: string;
  variant?: "default" | "featured" | "compact";
  metaLayout?: "default" | "stacked";
  showBookmark?: boolean;
}

const {
  talkId,
  title,
  speakers = [],
  typeName,
  mode,
  start,
  description,
  anchor = false,
  class: className = "",
  variant = "default",
  metaLayout = "default",
  showBookmark = true,
} = Astro.props;

const variantClasses: Record<string, string> = {
  default:
    "block rounded-lg border border-border bg-card px-5 py-3 scroll-mt-24 target:ring-2 target:ring-primary group/card relative isolate transition-all hover:shadow-md hover:border-primary/50 hover:bg-accent/30",
  featured:
    "block rounded-none border-0 bg-transparent px-0 py-0 scroll-mt-24 target:ring-2 target:ring-primary group/card relative isolate",
  compact:
    "block rounded-none border-0 bg-transparent px-0 py-0 scroll-mt-24 target:ring-2 target:ring-primary group/card relative isolate",
};

const linkClass =
  `${variantClasses[variant] ?? variantClasses.default} ${className}`.trim();

const plainTitle = title.replace(/<[^>]*>/g, "");
const titleSize =
  variant === "featured"
    ? "text-xl md:text-[1.85rem]"
    : plainTitle.length > 50
      ? "text-sm"
      : "text-base";
const titleClamp = anchor
  ? ""
  : variant === "featured"
    ? "line-clamp-3"
    : "line-clamp-2";

const resolvedMetaLayout =
  metaLayout === "stacked"
    ? "stacked"
    : variant === "compact"
      ? "compact"
      : "default";

function formatCardTime(iso?: string) {
  const formatted = formatConferenceDate(iso, {
    weekday: "short",
    hour: "numeric",
    minute: "2-digit",
  });

  return formatted || undefined;
}

const timeLabel = formatCardTime(start);
---

<div
  id={anchor ? talkId : undefined}
  class={linkClass}
  data-starring-card
  data-starring-card-variant={variant}
>
  {
    showBookmark && (
      <button
        class="star-btn"
        data-star-btn={talkId}
        aria-label="Bookmark this session"
        aria-pressed="false"
        title="Bookmark this session"
      >
        <BookmarkIcon class="star-icon star-icon-empty" strokeWidth={1.5} />
        <BookmarkIcon
          class="star-icon star-icon-filled"
          filled
          strokeWidth={1.5}
        />
      </button>
    )
  }
  <div class:list={["flex items-start gap-3", showBookmark && "pr-8"]}>
    <span
      class:list={[
        "starring-card-arrow shrink-0 transition-colors",
        variant === "featured"
          ? "text-primary/55 pt-1 text-lg"
          : "text-primary/40 group-hover/card:text-primary",
      ]}>&rarr;</span
    >
    <div class="min-w-0 flex-1">
      <a href={anchor ? `#${talkId}` : `/event/${talkId}`}>
        <span
          class:list={[
            "starring-card-title text-foreground leading-5 font-semibold",
            titleSize,
            titleClamp,
            !anchor && variant === "default" && "h-10",
            variant === "featured" && "leading-tight",
          ]}
          set:html={title}
        />
        <span class="absolute inset-0 z-10 h-full w-full"></span>
      </a>
      {
        description && variant === "featured" && (
          <p class="starring-card-description">{description}</p>
        )
      }
      <CardMeta
        typeName={typeName}
        timeLabel={timeLabel}
        speakers={speakers}
        layout={resolvedMetaLayout}
        size={variant === "featured" ? "sm" : "base"}
        class="starring-card-meta"
      />
      {isRemoteAccessible(mode) && (
        <span class="starring-card-remote-badge" title="Available via livestream">
          <span class="starring-card-remote-icon" set:html={remoteBadgeSvg} />
          <span>Livestreamed</span>
        </span>
      )}
    </div>
  </div>
</div>

<style>
  .star-btn {
    position: absolute;
    top: -0.2rem;
    right: 1rem;
    z-index: 20;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 2rem;
    padding: 0;
    border: none;
    background: transparent;
    color: color-mix(in oklch, var(--foreground), transparent 65%);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: color 150ms ease;
  }

  .star-btn:hover {
    color: color-mix(in oklch, var(--foreground), transparent 30%);
  }

  .star-btn.is-starred {
    color: var(--primary);
  }

  [data-starring-card-variant="featured"] .star-btn {
    top: 0;
    right: 0;
    font-size: 1.75rem;
    width: 1.75rem;
  }

  [data-starring-card-variant="compact"] .star-btn {
    top: 0;
    right: 0;
    font-size: 1.5rem;
    width: 1.5rem;
  }

  .star-btn :global(.star-icon) {
    width: 1em;
    height: 1em;
    transform-origin: top center;
    transition: transform 150ms ease;
  }

  .star-btn :global(.star-icon-filled) {
    display: none;
  }

  .star-btn.is-starred :global(.star-icon-empty) {
    display: none;
  }

  .star-btn.is-starred :global(.star-icon-filled) {
    display: block;
  }

  .star-btn:focus-visible {
    outline: 2px solid color-mix(in oklch, var(--primary), transparent 30%);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .star-btn {
      transition: none;
    }
  }

  .starring-card-description {
    margin-top: 0.7rem;
    max-width: 32ch;
    color: color-mix(in oklch, var(--foreground), var(--background) 34%);
    font-size: 0.94rem;
    line-height: 1.58;
    text-wrap: pretty;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    line-clamp: 6;
  }

  .starring-card-remote-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    margin-top: 0.35rem;
    color: var(--muted-foreground);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .starring-card-remote-icon {
    display: inline-flex;
    width: 0.85em;
    height: 0.85em;
  }

  .starring-card-remote-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 639px) {
    .starring-card-description {
      font-size: 0.9rem;
      line-height: 1.5;
    }
  }
</style>

<script>
  import { applyStarredState, initStarredHandlers } from "@/scripts/starred";
  applyStarredState();
  initStarredHandlers();
</script>
