---
interface Speaker {
  name: string;
  id?: string;
}

interface Props {
  talkId: string;
  title: string;
  speakers?: Speaker[];
  typeName: string;
  description?: string;
  anchor?: boolean;
}

const {
  talkId,
  title,
  speakers = [],
  typeName,
  description,
  anchor = false,
} = Astro.props;

const badgeColors: Record<string, string> = {
  Presentation: "event-badge event-badge-presentation",
  "Lightning Talk": "event-badge event-badge-lightning",
  "Discussion / Panel": "event-badge event-badge-panel",
  Workshop: "event-badge event-badge-workshop",
};

const baseClass =
  "block rounded-lg border border-border bg-card px-5 py-3 scroll-mt-24 target:ring-2 target:ring-primary";
const linkClass = `${baseClass} group/card relative isolate transition-all hover:shadow-md hover:border-primary/50 hover:bg-accent/30`;

const plainTitle = title.replace(/<[^>]*>/g, "");
const titleSize = plainTitle.length > 50 ? "text-sm" : "text-base";
const titleClamp = anchor ? "" : "line-clamp-2";
---

<div id={anchor ? talkId : undefined} class={linkClass}>
  <div class="flex items-center gap-3">
    <span
      class="text-primary/40 group-hover/card:text-primary shrink-0 transition-colors"
      >&rarr;</span
    >
    <div class="min-w-0 flex-1">
      <a href={anchor ? `#${talkId}` : `/event/${talkId}`}>
        <span
          class:list={[
            "text-foreground leading-5 font-semibold",
            titleSize,
            titleClamp,
            !anchor && "h-10",
          ]}
          set:html={title}
        />
        <span class="absolute inset-0 z-10 h-full w-full"></span>
      </a>
      <span
        class="text-muted-foreground mt-1 flex flex-wrap items-center gap-1.5 text-xs"
      >
        <span
          class:list={[
            "rounded-full px-2 py-0.5 font-medium whitespace-nowrap",
            badgeColors[typeName] || "event-badge event-badge-activity",
          ]}
        >
          {typeName}
        </span>
        {
          speakers.map((s, i) => (
            <>
              {i > 0 && <span>, </span>}
              {s.name}
              {s.id && (
                <>
                  {" · "}
                  <a
                    class="text-primary z-20 cursor-pointer hover:underline"
                    href={`/profile/${s.id}`}
                  >
                    @{s.id}
                  </a>
                </>
              )}
            </>
          ))
        }
      </span>
      {
        description && (
          <p class="text-muted-foreground mt-1.5 line-clamp-2 text-xs">
            {description}
          </p>
        )
      }
    </div>
  </div>
</div>
