---
interface Speaker {
  name: string;
  id?: string;
}

interface Props {
  talkId: string;
  title: string;
  speakers?: Speaker[];
  typeName: string;
  anchor?: boolean;
}

const { talkId, title, speakers = [], typeName, anchor = false } = Astro.props;

const badgeColors: Record<string, string> = {
  Presentation: "bg-blue-100 text-blue-700",
  "Lightning Talk": "bg-amber-100 text-amber-700",
  "Discussion / Panel": "bg-purple-100 text-purple-700",
  Workshop: "bg-emerald-100 text-emerald-700",
};

const baseClass =
  "block rounded-lg border border-border bg-white px-5 py-3 scroll-mt-24 target:ring-2 target:ring-blue-400";
const linkClass = `${baseClass} group/card relative isolate transition-all hover:shadow-md hover:border-blue-300 hover:bg-blue-50/30`;

const plainTitle = title.replace(/<[^>]*>/g, "");
const titleSize = plainTitle.length > 50 ? "text-sm" : "text-base";
const titleClamp = anchor ? "" : "line-clamp-2";
---

<div id={anchor ? talkId : undefined} class={linkClass}>
  <div class="flex items-center gap-3">
    <span
      class="text-primary/40 shrink-0 transition-colors group-hover/card:text-blue-500"
      >&rarr;</span
    >
    <div class="min-w-0 flex-1">
      <a href={anchor ? `#${talkId}` : `/event/${talkId}`}>
        <span
          class:list={[
            "leading-5 font-semibold text-gray-900",
            titleSize,
            titleClamp,
            !anchor && "h-10",
          ]}
          set:html={title}
        />
        <span class="absolute inset-0 z-10 h-full w-full"></span>
      </a>
      <span
        class="mt-1 flex flex-wrap items-center gap-1.5 text-xs text-gray-500"
      >
        <span
          class:list={[
            "rounded-full px-2 py-0.5 font-medium whitespace-nowrap",
            badgeColors[typeName] || "bg-gray-100 text-gray-600",
          ]}
        >
          {typeName}
        </span>
        {
          speakers.map((s, i) => (
            <>
              {i > 0 && <span>, </span>}
              {s.name}
              {s.id && (
                <>
                  {" · "}
                  <a
                    class="z-20 cursor-pointer text-blue-600 hover:underline"
                    href={`/profile/${s.id}`}
                  >
                    @{s.id}
                  </a>
                </>
              )}
            </>
          ))
        }
      </span>
    </div>
  </div>
</div>
