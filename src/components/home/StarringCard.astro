---
interface Speaker {
  name: string;
  id?: string;
}

interface Props {
  talkId: string;
  title: string;
  speakers?: Speaker[];
  typeName: string;
  start?: string;
  description?: string;
  anchor?: boolean;
  class?: string;
  variant?: "default" | "featured" | "compact";
  metaLayout?: "default" | "stacked";
}

const {
  talkId,
  title,
  speakers = [],
  typeName,
  start,
  description,
  anchor = false,
  class: className = "",
  variant = "default",
  metaLayout = "default",
} = Astro.props;

const badgeColors: Record<string, string> = {
  Presentation: "event-badge event-badge-presentation",
  "Lightning Talk": "event-badge event-badge-lightning",
  "Discussion / Panel": "event-badge event-badge-panel",
  Workshop: "event-badge event-badge-workshop",
};

const variantClasses: Record<string, string> = {
  default:
    "block rounded-lg border border-border bg-card px-5 py-3 scroll-mt-24 target:ring-2 target:ring-primary group/card relative isolate transition-all hover:shadow-md hover:border-primary/50 hover:bg-accent/30",
  featured:
    "block rounded-none border-0 bg-transparent px-0 py-0 scroll-mt-24 target:ring-2 target:ring-primary group/card relative isolate",
  compact:
    "block rounded-none border-0 bg-transparent px-0 py-0 scroll-mt-24 target:ring-2 target:ring-primary group/card relative isolate",
};

const linkClass =
  `${variantClasses[variant] ?? variantClasses.default} ${className}`.trim();

const plainTitle = title.replace(/<[^>]*>/g, "");
const titleSize =
  variant === "featured"
    ? "text-xl md:text-[1.85rem]"
    : plainTitle.length > 50
      ? "text-sm"
      : "text-base";
const titleClamp = anchor
  ? ""
  : variant === "featured"
    ? "line-clamp-3"
    : "line-clamp-2";
const isStackedMeta = metaLayout === "stacked";

function formatCardTime(iso?: string) {
  if (!iso) return undefined;
  const date = new Date(iso);
  if (Number.isNaN(date.getTime())) return undefined;

  return date.toLocaleString("en-US", {
    weekday: "short",
    hour: "numeric",
    minute: "2-digit",
  });
}

const timeLabel = formatCardTime(start);
---

<div
  id={anchor ? talkId : undefined}
  class={linkClass}
  data-starring-card
  data-starring-card-variant={variant}
>
  <div class="flex items-center gap-3">
    <span
      class:list={[
        "starring-card-arrow shrink-0 transition-colors",
        variant === "featured"
          ? "text-primary/55 pt-1 text-lg"
          : "text-primary/40 group-hover/card:text-primary",
      ]}>&rarr;</span
    >
    <div class="min-w-0 flex-1">
      <a href={anchor ? `#${talkId}` : `/event/${talkId}`}>
        <span
          class:list={[
            "starring-card-title text-foreground leading-5 font-semibold",
            titleSize,
            titleClamp,
            !anchor && variant === "default" && "h-10",
            variant === "featured" && "leading-tight",
          ]}
          set:html={title}
        />
        <span class="absolute inset-0 z-10 h-full w-full"></span>
      </a>
      {
        description && variant === "featured" && (
          <p class="starring-card-description">{description}</p>
        )
      }
      {
        isStackedMeta ? (
          <div class="starring-card-stack-meta text-muted-foreground mt-1.5">
            <span class="starring-card-meta-row starring-card-meta-row-primary">
              <span
                class:list={[
                  "rounded-full px-2 py-0.5 font-medium whitespace-nowrap",
                  badgeColors[typeName] || "event-badge event-badge-activity",
                ]}
              >
                {typeName}
              </span>
              {timeLabel && (
                <span class="starring-card-time border-border/70 rounded-full border px-2 py-0.5 font-medium whitespace-nowrap">
                  {timeLabel}
                </span>
              )}
            </span>
            {speakers.length > 0 && (
              <span class="starring-card-speaker-list">
                {speakers.map((speaker) => (
                  <span class="starring-card-speaker-line">
                    {speaker.id && (
                      <a
                        class="text-primary z-20 cursor-pointer hover:underline"
                        href={`/profile/${speaker.id}`}
                      >
                        @{speaker.id}
                      </a>
                    )}
                    {speaker.id && (
                      <span class="starring-card-link-separator">-</span>
                    )}
                    <span>{speaker.name}</span>
                  </span>
                ))}
              </span>
            )}
          </div>
        ) : variant === "compact" ? (
          <div class="starring-card-compact-meta text-muted-foreground mt-1.5">
            <span class="starring-card-meta-row starring-card-meta-row-primary">
              {timeLabel && (
                <span class="starring-card-time border-border/70 rounded-full border px-2 py-0.5 font-medium whitespace-nowrap">
                  {timeLabel}
                </span>
              )}
              <span
                class:list={[
                  "rounded-full px-2 py-0.5 font-medium whitespace-nowrap",
                  badgeColors[typeName] || "event-badge event-badge-activity",
                ]}
              >
                {typeName}
              </span>
            </span>
            {speakers.length > 0 && (
              <span class="starring-card-meta-row starring-card-meta-row-secondary">
                {speakers.map((speaker, index) => (
                  <span class="starring-card-speaker-unit">
                    {index > 0 && (
                      <span class="starring-card-link-separator">,</span>
                    )}
                    <span>{speaker.name}</span>
                    {speaker.id && (
                      <>
                        <span class="starring-card-link-separator">·</span>
                        <a
                          class="text-primary z-20 cursor-pointer hover:underline"
                          href={`/profile/${speaker.id}`}
                        >
                          @{speaker.id}
                        </a>
                      </>
                    )}
                  </span>
                ))}
              </span>
            )}
          </div>
        ) : (
          <span
            class:list={[
              "starring-card-meta text-muted-foreground mt-1 flex flex-wrap items-center gap-1.5",
              variant === "featured" ? "text-sm" : "text-xs",
            ]}
          >
            {timeLabel && (
              <span class="starring-card-time border-border/70 rounded-full border px-2 py-0.5 font-medium whitespace-nowrap">
                {timeLabel}
              </span>
            )}
            <span
              class:list={[
                "rounded-full px-2 py-0.5 font-medium whitespace-nowrap",
                badgeColors[typeName] || "event-badge event-badge-activity",
              ]}
            >
              {typeName}
            </span>
            {speakers.map((s, i) => (
              <>
                {i > 0 && <span>, </span>}
                {s.name}
                {s.id && (
                  <>
                    {" · "}
                    <a
                      class="text-primary z-20 cursor-pointer hover:underline"
                      href={`/profile/${s.id}`}
                    >
                      @{s.id}
                    </a>
                  </>
                )}
              </>
            ))}
          </span>
        )
      }
    </div>
  </div>
</div>

<style>
  .starring-card-description {
    margin-top: 0.7rem;
    max-width: 32ch;
    color: color-mix(in oklch, var(--foreground), var(--background) 34%);
    font-size: 0.94rem;
    line-height: 1.58;
    text-wrap: pretty;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    line-clamp: 6;
  }

  .starring-card-compact-meta {
    display: grid;
    gap: 0.32rem;
    font-size: 0.73rem;
    line-height: 1.25;
  }

  .starring-card-stack-meta {
    display: grid;
    gap: 0.42rem;
    font-size: 0.76rem;
    line-height: 1.3;
  }

  .starring-card-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.45rem;
    min-width: 0;
  }

  .starring-card-meta-row-primary {
    align-items: center;
  }

  .starring-card-meta-row-secondary {
    color: color-mix(in oklch, var(--foreground), var(--background) 42%);
    font-weight: 500;
  }

  .starring-card-speaker-list {
    display: grid;
    gap: 0.22rem;
    color: color-mix(in oklch, var(--foreground), var(--background) 42%);
    font-weight: 500;
  }

  .starring-card-speaker-line {
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: baseline;
    gap: 0.3rem;
    max-width: 100%;
    white-space: nowrap;
  }

  .starring-card-speaker-unit {
    display: inline-flex;
    align-items: center;
    gap: 0.24rem;
    white-space: nowrap;
  }

  .starring-card-meta-row-links {
    gap: 0.28rem 0.4rem;
    font-size: 0.78rem;
  }

  .starring-card-link-separator {
    color: color-mix(in oklch, var(--foreground), var(--background) 64%);
  }

  @media (max-width: 639px) {
    .starring-card-description {
      font-size: 0.9rem;
      line-height: 1.5;
    }
  }
</style>
