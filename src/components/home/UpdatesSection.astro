---
import Card from "@/components/ui/card.astro";
import Button from "@/components/ui/button.astro";
import BreakoutSection from "@/components/ui/BreakoutSection.astro";
import PaperCard from "@/components/ui/PaperCard.astro";
import PanelHeader from "@/components/ui/PanelHeader.astro";
import SectionKicker from "@/components/ui/SectionKicker.astro";
import InlineLink from "@/components/ui/InlineLink.astro";
import NewsClipList from "@/components/ui/NewsClipList.astro";
import { BlueskyPost } from "@astro-community/astro-embed-bluesky";
import { getLiveCollection } from "astro:content";
import { BlueskyFeed } from "./BlueskyFeed";
import { FEED_URL, fetchFeedPage } from "@/lib/bsky";

let initialData;
try {
  initialData = await fetchFeedPage();
} catch (e) {
  console.error("Failed to fetch initial feed:", e);
  initialData = { posts: [], cursor: undefined };
}

const blueskyResult = await getLiveCollection("blueskyPosts", {
  limit: 20,
  type: "posts_no_replies",
});
const latestPost =
  blueskyResult.entries?.find(
    (entry) => entry.data.author.handle === "atprotocol.dev",
  ) ?? blueskyResult.entries?.at(0);

const leafletResult = await getLiveCollection("leafletPosts");
const newsPosts = (leafletResult.entries ?? [])
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() -
      new Date(a.data.publishedAt).getTime(),
  )
  .slice(0, 5);

function buildNewsUrl(basePath: string, rkey: string) {
  const base = basePath
    ? basePath.startsWith("http")
      ? basePath
      : `https://${basePath}`
    : "https://leaflet.pub";
  return `${base.replace(/\/$/, "")}/${rkey}`;
}

const newsItems = newsPosts.map((post) => ({
  href: buildNewsUrl(post.data.basePath, post.data.rkey),
  imageUrl: post.data.imageUrl || undefined,
  date: post.data.publishedAt,
  title: post.data.title,
  description: post.data.description || undefined,
}));
---

<BreakoutSection maxWidth="74rem" class="updates-section" id="feed">
  <Card title="Dispatches from the ATmosphere" class="updates-shell">
    <div class="updates-grid">
      <section class="updates-feed-card">
        <PanelHeader kicker="Conference feed" />

        <p class="text-muted-foreground mb-4 max-w-[64ch] text-sm sm:text-base">
          Follow the AtmosphereConf conversation as it unfolds in our feed, or
          head to our leaflet and profile for more of our voice.
        </p>

        <div class="updates-feed-frame">
          <BlueskyFeed
            client:visible
            initialData={initialData}
            height="100%"
            emptyMessage="Goodstuff is still gathering dispatches."
            loadingMessage="Gathering more dispatches..."
          />
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-3">
          <Button
            href={FEED_URL}
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open the full feed
          </Button>
          <InlineLink href="https://www.graze.social/" external>
            Powered by Graze
          </InlineLink>
        </div>
      </section>

      <div class="updates-side-rail">
        <PaperCard
          variant="outline"
          tapePosition="left"
          tapeWidth="lg"
          class="updates-note"
        >
          <div class="updates-note-inner" id="news" data-panel="news">
            <PanelHeader
              kicker="Leaflet clippings"
              linkHref="https://news.atmosphereconf.org"
              linkText="open archive"
              linkExternal
            />

            {
              newsItems.length > 0 ? (
                <NewsClipList items={newsItems} />
              ) : (
                <p class="updates-note-fallback">
                  The news desk is quiet for the moment. Fresh dispatches will
                  show up here as soon as they land.
                </p>
              )
            }
          </div>
        </PaperCard>

        <PaperCard
          variant="outline"
          tapePosition="right"
          tapeWidth="lg"
          class="updates-note"
        >
          <div class="updates-note-inner" data-panel="signal">
            <PanelHeader
              kicker="Latest from atprotocol.dev"
              linkHref="https://bsky.app/profile/atprotocol.dev"
              linkText="profile"
              linkExternal
            />

            {
              latestPost ? (
                <div class="updates-signal-embed">
                  <BlueskyPost post={latestPost.data} />
                </div>
              ) : (
                <p class="updates-note-fallback">
                  No official bulletin is pinned yet. Check back soon for the
                  next note from the protocol team.
                </p>
              )
            }
          </div>
        </PaperCard>
      </div>
    </div>
  </Card>
</BreakoutSection>

<script>
  function syncUpdatesHeight() {
    const section = document.querySelector("#feed");
    if (!section) return;

    const sideRail = section.querySelector(".updates-side-rail");
    if (!sideRail) return;

    if (!window.matchMedia("(min-width: 960px)").matches) {
      (section as HTMLElement).style.removeProperty("--updates-rail-height");
      return;
    }

    const railHeight = Math.ceil(sideRail.getBoundingClientRect().height);
    (section as HTMLElement).style.setProperty(
      "--updates-rail-height",
      `${railHeight}px`,
    );
  }

  const updatesSection = document.querySelector("#feed");
  const updatesRail = updatesSection?.querySelector(".updates-side-rail");

  if (updatesRail && "ResizeObserver" in window) {
    const observer = new ResizeObserver(() => {
      requestAnimationFrame(syncUpdatesHeight);
    });
    observer.observe(updatesRail);
  }

  window.addEventListener("load", syncUpdatesHeight);
  window.addEventListener("resize", syncUpdatesHeight);
  document.addEventListener("astro:page-load", syncUpdatesHeight);
  syncUpdatesHeight();
</script>

<style>
  :global(.updates-shell) {
    overflow: visible;
  }

  .updates-grid {
    display: grid;
    gap: 1.25rem;
    align-items: start;
  }

  .updates-feed-card {
    position: relative;
    display: flex;
    min-height: 0;
    flex-direction: column;
    background: var(--card);
    box-shadow: none;
  }

  .updates-feed-card::after {
    display: none;
  }

  .updates-feed-frame {
    position: relative;
    z-index: 1;
    flex: 1;
    min-height: 0;
  }

  .updates-side-rail {
    display: grid;
    gap: 1rem;
  }

  :global(.updates-note) {
    border-radius: var(--paper-radius-sm);
    box-shadow: var(--paper-shadow);
  }

  .updates-note-inner {
    padding: 1.2rem;
  }

  .updates-note-fallback {
    margin-top: 1rem;
    color: var(--muted-foreground);
    line-height: 1.55;
  }

  .updates-signal-embed {
    margin-top: 1rem;
    --bluesky-color-background: var(--card);
    --bluesky-color-background-hover: var(--muted);
    --bluesky-color-text: var(--foreground);
    --bluesky-color-text-secondary: var(--muted-foreground);
    --bluesky-color-link: var(--primary);
    --bluesky-color-border: color-mix(in oklch, var(--border), transparent 35%);
    --bluesky-card-border: 1px solid
      color-mix(in oklch, var(--border), transparent 35%);
  }

  @media (min-width: 960px) {
    .updates-grid {
      display: flex;
      align-items: flex-start;
      gap: 1.1rem;
    }

    .updates-feed-card {
      flex: 2.3 1 0%;
      height: var(--updates-rail-height);
      min-width: 0;
    }

    .updates-side-rail {
      flex: 0.58 1 16.75rem;
      min-width: 16.75rem;
      align-self: flex-start;
    }
  }

  @media (max-width: 959px) {
    .updates-feed-frame {
      flex: none;
      height: clamp(24rem, 48vh, 31rem);
      min-height: 0;
    }
  }
</style>
