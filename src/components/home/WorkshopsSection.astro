---
import Card from "@/components/ui/card.astro";
import BreakoutSection from "@/components/ui/BreakoutSection.astro";
import ProgramDaySelector from "./ProgramDaySelector.astro";
import ProgramStage from "./ProgramStage.astro";
import ProgramDayRail from "./ProgramDayRail.astro";
import { getProgramDays, getRandomProgramRail } from "@/lib/program";

interface Props {
  mode?: "default" | "remote";
}

const { mode = "default" } = Astro.props;
const remote = mode === "remote";

const days = await getProgramDays();
const initialRails = Object.fromEntries(
  days.map((day) => [
    day.date,
    getRandomProgramRail(day.date, days, { remote }),
  ]),
);
const initialDayDate = days[0]?.date ?? "";
---

<BreakoutSection maxWidth="74rem">
  <Card title={remote ? "remote schedule" : "schedule"} class="program-shell">
    <p class="program-panel-copy program-intro-copy">
      {
        remote
          ? "The conference schedule, remote edition! While our Wednesday workshops are in-person, the rest of the conference is accessible from anywhere!"
          : "We have two days of pre-conference events and activities, happening Thursday, March 26th and Friday, March 27th. These are included in your tickets. There is a maximum capacity, so please do select activities in your ticket registration form."
      }
    </p>
    <div
      class="program-board"
      data-program-board
      data-remote={remote ? "true" : undefined}
    >
      <div class="program-grid">
        <ProgramDaySelector days={days} initialDate={initialDayDate} />

        <div class="program-primary-column">
          <ProgramStage
            days={days}
            initialDate={initialDayDate}
            remote={remote}
          />
        </div>

        <aside class="program-secondary-column">
          {
            days.map((day) => (
              <section
                data-program-side={day.date}
                class:list={[
                  "program-side-rail",
                  day.date !== initialDayDate && "hidden",
                ]}
                aria-hidden={day.date === initialDayDate ? "false" : "true"}
              >
                <ProgramDayRail rail={initialRails[day.date]} />
              </section>
            ))
          }
        </aside>
      </div>
    </div>
  </Card>
</BreakoutSection>

<script>
  import { applyStarredState } from "@/scripts/starred";

  function syncProgramStageHeight(board) {
    const stage = board.querySelector("[data-program-stage]");
    const activePaper = stage?.querySelector(".program-paper.is-active");
    if (!stage || !activePaper) return;

    const extra =
      Number.parseFloat(
        getComputedStyle(stage).getPropertyValue("--program-stage-extra"),
      ) || (window.matchMedia("(min-width: 1024px)").matches ? 18 : 22);
    stage.style.height = `${Math.ceil(activePaper.getBoundingClientRect().height + extra)}px`;
  }

  document.querySelectorAll("[data-program-board]").forEach((board) => {
    const dayButtons = [...board.querySelectorAll("[data-day-select]")];
    const dayPapers = [...board.querySelectorAll("[data-program-day]")];
    const sidePanels = [...board.querySelectorAll("[data-program-side]")];

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );

    // --- Lazy schedule loading ---
    const contentCache = new Map<string, Promise<string | null>>();

    const SESSION_PREFIX = "atm:sched:v3:";
    const SESSION_TTL = 2 * 60 * 1000; // 2 minutes

    function getSessionCache(date: string): string | null {
      try {
        const raw = sessionStorage.getItem(SESSION_PREFIX + date);
        if (!raw) return null;
        const { html, ts } = JSON.parse(raw);
        if (Date.now() - ts > SESSION_TTL) {
          sessionStorage.removeItem(SESSION_PREFIX + date);
          return null;
        }
        return html;
      } catch {
        return null;
      }
    }

    function setSessionCache(date: string, html: string) {
      try {
        sessionStorage.setItem(
          SESSION_PREFIX + date,
          JSON.stringify({ html, ts: Date.now() }),
        );
      } catch {}
    }

    function initRoomTabs(container: Element) {
      const tabs = container.querySelectorAll<HTMLElement>("[data-room-tab]");
      const panels =
        container.querySelectorAll<HTMLElement>("[data-room-panel]");
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const idx = tab.dataset.roomTab;
          tabs.forEach((t) => {
            const isActive = t === tab;
            t.classList.toggle("is-active", isActive);
            t.classList.toggle("border-l-2", isActive);
            t.classList.toggle("border-l-primary", isActive);
            t.classList.toggle("text-primary", isActive);
            t.classList.toggle("bg-accent/50", isActive);
            t.classList.toggle("text-muted-foreground", !isActive);
          });
          panels.forEach((p) => {
            p.classList.toggle("hidden", p.dataset.roomPanel !== idx);
          });
        });
      });
    }

    const isRemote = board.dataset.remote === "true";

    function prefetchDayContent(date: string) {
      if (contentCache.has(date)) return;
      const cached = getSessionCache(date);
      if (cached) {
        contentCache.set(date, Promise.resolve(cached));
        return;
      }
      const url = `/partials/program-day-content?date=${encodeURIComponent(date)}${isRemote ? "&mode=remote" : ""}`;
      contentCache.set(
        date,
        fetch(url).then((r) => {
          if (!r.ok) return null;
          return r.text().then((html) => {
            setSessionCache(date, html);
            return html;
          });
        }),
      );
    }

    async function loadDayContent(paper: Element, date: string) {
      const slot = paper.querySelector("[data-schedule-content]");
      if (!slot || slot.children.length > 0) return; // already loaded

      prefetchDayContent(date);
      const html = await contentCache.get(date);
      if (!html) return;

      slot.innerHTML = html;
      applyStarredState(slot);

      requestAnimationFrame(() => {
        const schedule = slot.querySelector(".day-schedule");
        if (!schedule) return;
        initRoomTabs(schedule);
        schedule.getBoundingClientRect();
        document.dispatchEvent(new CustomEvent("schedule:loaded"));
      });
    }

    // Prefetch on hover
    dayButtons.forEach((button) => {
      button.addEventListener("mouseenter", () => {
        const date = button.dataset.daySelect;
        if (date) prefetchDayContent(date);
      });
    });

    const refreshSidePanel = async (panel, date) => {
      try {
        const res = await fetch(
          `/partials/program-day-rail?date=${encodeURIComponent(date)}${isRemote ? "&mode=remote" : ""}`,
        );
        if (!res.ok) throw new Error("Failed to load day rail");
        panel.innerHTML = await res.text();
      } catch {
        return;
      }
    };

    const dayChangeCallbacks: Array<() => void> = [];
    const setSelectedDay = async (date, { refreshRail = false } = {}) => {
      // Lazy-load schedule content before switching
      const targetPaper = dayPapers.find((p) => p.dataset.programDay === date);
      if (targetPaper) await loadDayContent(targetPaper, date);

      dayButtons.forEach((button) => {
        const isActive = button.dataset.daySelect === date;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", String(isActive));
        button.setAttribute("tabindex", isActive ? "0" : "-1");
      });

      dayPapers.forEach((paper) => {
        const isActive = paper.dataset.programDay === date;
        paper.classList.toggle("is-active", isActive);
        paper.classList.toggle("is-under", !isActive);
        paper.setAttribute("aria-hidden", String(!isActive));

        if (isActive) {
          paper.removeAttribute("inert");
        } else {
          paper.setAttribute("inert", "");
        }
      });

      let activeSidePanel = null;
      sidePanels.forEach((panel) => {
        const isActive = panel.dataset.programSide === date;
        if (!isActive) {
          panel.classList.add("hidden");
          panel.setAttribute("aria-hidden", "true");
        }
        if (isActive) activeSidePanel = panel;
      });

      // If refreshing, fetch new content before showing the panel
      if (refreshRail && activeSidePanel) {
        await refreshSidePanel(activeSidePanel, date);
      }

      if (activeSidePanel) {
        activeSidePanel.classList.remove("hidden");
        activeSidePanel.setAttribute("aria-hidden", "false");
      }

      requestAnimationFrame(() => syncProgramStageHeight(board));
      dayChangeCallbacks.forEach((cb) => cb());
    };

    dayButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        history.replaceState(null, "", `#${button.id}`);
        await setSelectedDay(button.dataset.daySelect, { refreshRail: true });
      });
    });

    board.addEventListener("click", async (event) => {
      const jumpButton = event.target.closest("[data-show-day]");
      if (!(jumpButton instanceof HTMLElement)) return;

      const { showDay } = jumpButton.dataset;
      if (!showDay) return;

      event.preventDefault();

      const anchorButton = dayButtons.find(
        (btn) => btn.dataset.daySelect === showDay,
      );
      if (anchorButton) {
        history.replaceState(null, "", `#${anchorButton.id}`);
      }

      await setSelectedDay(showDay, { refreshRail: true });

      const scrollTarget = anchorButton || board;
      scrollTarget.scrollIntoView({
        block: "start",
        behavior: prefersReducedMotion.matches ? "auto" : "smooth",
      });
    });

    const applyHash = async (scroll = true) => {
      const hash = location.hash.replace("#", "");
      if (!hash) return;

      const matchedButton = dayButtons.find((btn) => btn.id === hash);
      if (!matchedButton) return;

      const date = matchedButton.dataset.daySelect;
      if (!date) return;

      await setSelectedDay(date, { refreshRail: true });

      if (scroll) {
        matchedButton.scrollIntoView({
          block: "start",
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
        });
      }
    };

    // On back/forward navigation, don't scroll to hash — let scroll restoration handle it
    const navEntry = performance.getEntriesByType("navigation")[0] as
      | PerformanceNavigationTiming
      | undefined;
    const isBackForward = navEntry?.type === "back_forward";
    applyHash(!isBackForward);
    window.addEventListener("hashchange", () => applyHash());

    const resizeObserver =
      "ResizeObserver" in window
        ? new ResizeObserver(() =>
            requestAnimationFrame(() => syncProgramStageHeight(board)),
          )
        : null;

    dayPapers.forEach((paper) => resizeObserver?.observe(paper));

    window.addEventListener("resize", () => syncProgramStageHeight(board));
    document.addEventListener("astro:page-load", () =>
      syncProgramStageHeight(board),
    );
    // Auto-select the day with the next upcoming event (conference timezone)
    function getUpcomingDayDate(): string | undefined {
      const today = new Intl.DateTimeFormat("en-CA", {
        timeZone: "America/Vancouver",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).format(new Date());
      const dates = dayButtons
        .map((btn) => btn.dataset.daySelect)
        .filter((d): d is string => !!d);
      return dates.find((date) => date >= today);
    }

    const upcomingDay = !location.hash ? getUpcomingDayDate() : undefined;
    const initialDate = upcomingDay ??
      dayButtons.find((button) => button.classList.contains("is-active"))
        ?.dataset.daySelect ?? dayButtons[0]?.dataset.daySelect;

    if (initialDate) {
      setSelectedDay(initialDate);
    } else {
      syncProgramStageHeight(board);
    }

    // --- Floating prev/next day nav (appended to body to avoid transform ancestors) ---
    const selectorPanel = board.querySelector(".program-selector-panel");
    if (selectorPanel && dayButtons.length > 1) {
      const dayNav = document.createElement("nav");
      dayNav.className = "program-day-nav";
      dayNav.setAttribute("aria-label", "Previous / next day");
      dayNav.innerHTML = `
        <button type="button" class="program-day-nav-btn program-day-nav-btn--prev" data-day-nav-prev aria-label="Previous day">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button type="button" class="program-day-nav-btn program-day-nav-btn--next" data-day-nav-next aria-label="Next day">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      `;
      document.body.appendChild(dayNav);

      const prevBtn = dayNav.querySelector<HTMLButtonElement>(
        "[data-day-nav-prev]",
      )!;
      const nextBtn = dayNav.querySelector<HTMLButtonElement>(
        "[data-day-nav-next]",
      )!;

      let selectorVisible = true;
      let boardVisible = true;

      const stage = board.querySelector("[data-program-stage]") || board;
      const headerHeight = 60; // ~3.75rem

      function positionNav() {
        const stageRect = stage.getBoundingClientRect();
        const visibleTop = Math.max(stageRect.top, headerHeight);
        const visibleBottom = Math.min(stageRect.bottom, window.innerHeight);
        const centerY = (visibleTop + visibleBottom) / 2;

        // Match the paper's tilt so buttons track the rotated edges (desktop only)
        const isDesktop = window.matchMedia("(min-width: 768px)").matches;
        const tiltDeg = isDesktop
          ? parseFloat(
              getComputedStyle(stage).getPropertyValue("--program-paper-tilt"),
            ) || 0
          : 0;

        dayNav.style.top = `${centerY}px`;
        dayNav.style.left = `${stageRect.left}px`;
        dayNav.style.width = `${stageRect.width}px`;
        dayNav.style.transform = `translateY(-50%) rotate(${tiltDeg}deg)`;
      }

      function updateNavVisibility() {
        const shouldShow = !selectorVisible && boardVisible;
        dayNav.classList.toggle("is-visible", shouldShow);
        if (shouldShow) requestAnimationFrame(positionNav);
      }

      const selectorObserver = new IntersectionObserver(
        ([entry]) => {
          selectorVisible = entry.isIntersecting;
          updateNavVisibility();
        },
        { threshold: 0, rootMargin: "-40% 0px 0px 0px" },
      );
      selectorObserver.observe(selectorPanel);

      const boardObserver = new IntersectionObserver(
        ([entry]) => {
          boardVisible = entry.isIntersecting;
          updateNavVisibility();
        },
        { threshold: 0 },
      );
      boardObserver.observe(stage);

      let rafId = 0;
      function schedulePosition() {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(positionNav);
      }
      window.addEventListener("scroll", schedulePosition, { passive: true });
      window.addEventListener("resize", schedulePosition, { passive: true });

      function getActiveIndex(): number {
        return dayButtons.findIndex((b) => b.classList.contains("is-active"));
      }

      function updateNavLabels() {
        const idx = getActiveIndex();
        prevBtn.hidden = !dayButtons[idx - 1];
        nextBtn.hidden = !dayButtons[idx + 1];
      }

      dayChangeCallbacks.push(updateNavLabels);

      prevBtn.addEventListener("click", async () => {
        const idx = getActiveIndex();
        const prev = dayButtons[idx - 1];
        if (!prev) return;
        history.replaceState(null, "", `#${prev.id}`);
        await setSelectedDay(prev.dataset.daySelect!, { refreshRail: true });
      });

      nextBtn.addEventListener("click", async () => {
        const idx = getActiveIndex();
        const next = dayButtons[idx + 1];
        if (!next) return;
        history.replaceState(null, "", `#${next.id}`);
        await setSelectedDay(next.dataset.daySelect!, { refreshRail: true });
      });

      updateNavLabels();
    }
  });
</script>

<style>
  :global(.themed-card.program-shell) {
    overflow: visible !important;
  }

  /* Floating prev/next day nav — global because element is appended to body */
  :global(.program-day-nav) {
    position: fixed !important;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 0.5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 250ms ease;
    /* JS sets top/left/width/transform to match the schedule stage */
  }

  :global(.program-day-nav.is-visible) {
    opacity: 1;
  }

  :global(.program-day-nav.is-visible .program-day-nav-btn) {
    pointer-events: auto;
  }

  :global(.program-day-nav-btn) {
    pointer-events: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 2px solid var(--primary);
    border-radius: var(--pill-radius);
    background: var(--card);
    color: var(--primary);
    opacity: 0.7;
    backdrop-filter: blur(6px);
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.08);
    transition:
      opacity 150ms ease,
      background 150ms ease,
      color 150ms ease;
  }

  :global(.program-day-nav-btn:hover) {
    opacity: 1;
    background: color-mix(in srgb, var(--card), var(--primary) 8%);
    color: var(--primary);
  }

  :global(.program-day-nav-btn:focus-visible) {
    opacity: 1;
    outline: 2px solid color-mix(in oklch, var(--primary), transparent 30%);
    outline-offset: 2px;
  }

  :global(.program-day-nav-btn[hidden]) {
    display: none;
  }

  :global(.program-day-nav-btn svg) {
    flex: none;
  }

  :global(.program-day-nav-btn--prev) {
    margin-right: auto;
    margin-left: -1rem;
  }

  :global(.program-day-nav-btn--next) {
    margin-left: auto;
    margin-right: -1rem;
  }

  @media (max-width: 767px) {
    :global(.program-day-nav-btn) {
      width: 2rem;
      height: 2rem;
      box-shadow:
        0 0 0 3px var(--card),
        0 0 10px 4px color-mix(in srgb, var(--card), transparent 30%);
    }

    :global(.program-day-nav-btn--prev) {
      margin-left: -1.5rem;
    }

    :global(.program-day-nav-btn--next) {
      margin-right: -1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.program-day-nav-btn) {
      transition: none;
    }
  }

  .program-grid {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .program-primary-column,
  .program-secondary-column {
    display: grid;
    gap: 1rem;
    min-width: 0;
    align-content: start;
  }

  .program-secondary-column,
  .program-side-rail {
    position: relative;
    z-index: 1;
  }

  :global(.program-panel-copy) {
    color: var(--muted-foreground);
    max-width: 62ch;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .program-intro-copy {
    margin-bottom: 1rem;
    max-width: 80ch;
  }

  .program-side-rail {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 1023px) {
    :global(.breakout) {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .program-grid {
      grid-template-columns: minmax(0, 1.62fr) minmax(19rem, 0.86fr);
      gap: 2rem;
      grid-template-areas:
        "selector selector"
        "main spotlight";
    }

    .program-grid > :global(:first-child) {
      grid-area: selector;
    }

    .program-primary-column {
      grid-area: main;
    }

    .program-secondary-column {
      grid-area: spotlight;
      padding-top: 0.45rem;
      z-index: 3;
    }
  }
</style>
