---
import Card from "@/components/ui/card.astro";
import BreakoutSection from "@/components/ui/BreakoutSection.astro";
import SectionKicker from "@/components/ui/SectionKicker.astro";
import ProgramDaySelector from "./ProgramDaySelector.astro";
import ProgramStage from "./ProgramStage.astro";
import ProgramDayRail from "./ProgramDayRail.astro";
import { getProgramDays, getRandomProgramRail } from "@/lib/program";

const days = await getProgramDays();
const initialRails = Object.fromEntries(
  days.map((day) => [day.date, getRandomProgramRail(day.date, days)]),
);
const initialDayDate = days[0]?.date ?? "";
---

<BreakoutSection maxWidth="76rem">
  <Card title="schedule" class="program-shell">
    <p class="program-panel-copy program-intro-copy">
      We have two days of pre-conference events and activities, happening
      Thursday, March 26th and Friday, March 27th. These are included in your
      tickets. There is a maximum capacity, so please do select activities in
      your ticket registration form.
    </p>
    <div class="program-board" data-program-board>
      <div class="program-grid">
        <ProgramDaySelector days={days} initialDate={initialDayDate} />

        <div class="program-primary-column">
          <ProgramStage days={days} initialDate={initialDayDate} />
        </div>

        <aside class="program-secondary-column">
          {
            days.map((day) => (
              <section
                data-program-side={day.date}
                class:list={[
                  "program-side-rail",
                  day.date !== initialDayDate && "hidden",
                ]}
                aria-hidden={day.date === initialDayDate ? "false" : "true"}
              >
                <ProgramDayRail rail={initialRails[day.date]} />
              </section>
            ))
          }
        </aside>
      </div>
    </div>
  </Card>
</BreakoutSection>

<script>
  function syncProgramStageHeight(board) {
    const stage = board.querySelector("[data-program-stage]");
    const activePaper = stage?.querySelector(".program-paper.is-active");
    if (!stage || !activePaper) return;

    const extra = window.matchMedia("(min-width: 1024px)").matches ? 46 : 28;
    stage.style.height = `${Math.ceil(activePaper.getBoundingClientRect().height + extra)}px`;
  }

  document.querySelectorAll("[data-program-board]").forEach((board) => {
    const dayButtons = [...board.querySelectorAll("[data-day-select]")];
    const dayPapers = [...board.querySelectorAll("[data-program-day]")];
    const sidePanels = [...board.querySelectorAll("[data-program-side]")];

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );

    const refreshSidePanel = async (panel, date) => {
      try {
        const res = await fetch(
          `/partials/program-day-rail?date=${encodeURIComponent(date)}`,
        );
        if (!res.ok) throw new Error("Failed to load day rail");
        panel.innerHTML = await res.text();
      } catch {
        return;
      }
    };

    const setSelectedDay = async (date, { refreshRail = false } = {}) => {
      dayButtons.forEach((button) => {
        const isActive = button.dataset.daySelect === date;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", String(isActive));
        button.setAttribute("tabindex", isActive ? "0" : "-1");
      });

      dayPapers.forEach((paper) => {
        const isActive = paper.dataset.programDay === date;
        paper.classList.toggle("is-active", isActive);
        paper.classList.toggle("is-under", !isActive);
        paper.setAttribute("aria-hidden", String(!isActive));

        if (isActive) {
          paper.removeAttribute("inert");
        } else {
          paper.setAttribute("inert", "");
        }
      });

      let activeSidePanel = null;
      sidePanels.forEach((panel) => {
        const isActive = panel.dataset.programSide === date;
        panel.classList.toggle("hidden", !isActive);
        panel.setAttribute("aria-hidden", String(!isActive));
        if (isActive) activeSidePanel = panel;
      });

      requestAnimationFrame(() => syncProgramStageHeight(board));

      if (refreshRail && activeSidePanel) {
        await refreshSidePanel(activeSidePanel, date);
      }
    };

    dayButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        await setSelectedDay(button.dataset.daySelect, { refreshRail: true });
      });
    });

    board.addEventListener("click", async (event) => {
      const jumpButton = event.target.closest("[data-show-day]");
      if (!(jumpButton instanceof HTMLElement)) return;

      const { showDay } = jumpButton.dataset;
      if (!showDay) return;

      await setSelectedDay(showDay, { refreshRail: true });

      if (window.matchMedia("(max-width: 1023px)").matches) {
        const activePaper = board.querySelector(
          `[data-program-day="${showDay}"]`,
        );
        activePaper?.scrollIntoView({
          block: "start",
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
        });
      }
    });

    const resizeObserver =
      "ResizeObserver" in window
        ? new ResizeObserver(() =>
            requestAnimationFrame(() => syncProgramStageHeight(board)),
          )
        : null;

    dayPapers.forEach((paper) => resizeObserver?.observe(paper));

    window.addEventListener("resize", () => syncProgramStageHeight(board));
    document.addEventListener("astro:page-load", () =>
      syncProgramStageHeight(board),
    );
    const initialDate =
      dayButtons.find((button) => button.classList.contains("is-active"))
        ?.dataset.daySelect ?? dayButtons[0]?.dataset.daySelect;

    if (initialDate) {
      setSelectedDay(initialDate);
    } else {
      syncProgramStageHeight(board);
    }
  });
</script>

<style>
  :global(.program-shell) {
    overflow: visible;
  }

  .program-grid {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .program-primary-column,
  .program-secondary-column {
    display: grid;
    gap: 1rem;
    min-width: 0;
    align-content: start;
  }

  .program-secondary-column,
  .program-side-rail {
    position: relative;
    z-index: 1;
  }

  :global(.program-panel-copy) {
    color: var(--muted-foreground);
    max-width: 62ch;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .program-intro-copy {
    margin-bottom: 1rem;
    max-width: 80ch;
  }

  .program-side-rail {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 1023px) {
    :global(.breakout) {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .program-grid {
      grid-template-columns: minmax(0, 1.62fr) minmax(19rem, 0.86fr);
      gap: 1.75rem;
      grid-template-areas:
        "selector selector"
        "main spotlight";
    }

    .program-grid > :global(:first-child) {
      grid-area: selector;
    }

    .program-primary-column {
      grid-area: main;
    }

    .program-secondary-column {
      grid-area: spotlight;
      padding-top: 0.45rem;
      z-index: 3;
    }
  }
</style>
