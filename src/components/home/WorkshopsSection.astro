---
import Card from "@/components/ui/card.astro";
import DaySchedule from "@/components/ui/DaySchedule.astro";
import ProgramDayRail from "./ProgramDayRail.astro";
import { getProgramDays, getRandomProgramRail } from "@/lib/program";

const days = await getProgramDays();
const initialRails = Object.fromEntries(
  days.map((day) => [day.date, getRandomProgramRail(day.date, days)]),
);
const initialDayDate = days[0]?.date ?? "";
---

<section class="program-breakout">
  <Card title="schedule" class="program-shell">
    <p class="program-panel-copy program-intro-copy">
      We have two days of pre-conference events and activities, happening
      Thursday, March 26th and Friday, March 27th. These are included in your
      tickets. There is a maximum capacity, so please do select activities in
      your ticket registration form.
    </p>
    <div class="program-board" data-program-board>
      <div class="program-grid">
        <section class="program-selector-panel">
          <div
            class="program-day-selector"
            role="tablist"
            aria-label="Program day"
          >
            {
              days.map((day, index) => (
                <button
                  type="button"
                  role="tab"
                  id={`program-day-tab-${day.date}`}
                  aria-controls={`program-day-panel-${day.date}`}
                  aria-selected={index === 0 ? "true" : "false"}
                  tabindex={index === 0 ? "0" : "-1"}
                  class:list={["program-day-chip", index === 0 && "is-active"]}
                  data-day-select={day.date}
                >
                  <span class="program-day-chip-kicker">{`// ${day.dayLabel}`}</span>
                  <span class="program-day-chip-title">{day.dateLabel}</span>
                  <span class="program-day-chip-meta">{day.seriesLabel}</span>
                </button>
              ))
            }
          </div>
        </section>

        <div class="program-primary-column">
          <section class="program-main-panel">
            <div class="program-stage" data-program-stage>
              {
                days.map((day) => (
                  <article
                    id={`program-day-panel-${day.date}`}
                    role="tabpanel"
                    aria-labelledby={`program-day-tab-${day.date}`}
                    aria-hidden={day.date === initialDayDate ? "false" : "true"}
                    inert={day.date !== initialDayDate}
                    data-program-day={day.date}
                    class:list={[
                      "program-paper",
                      day.accentClass,
                      day.date === initialDayDate ? "is-active" : "is-under",
                    ]}
                  >
                    <div class="program-paper-header">
                      <div>
                        <p class="program-paper-kicker">{`// ${day.dayLabel}`}</p>
                        <h3 class="program-paper-title">{day.dateLabel}</h3>
                        <p class="program-paper-subtitle">{day.subheading}</p>
                      </div>
                      <div class="program-paper-summary">
                        <span>{day.rooms.length} rooms</span>
                      </div>
                    </div>

                    <DaySchedule
                      events={day.events}
                      rooms={day.rooms}
                      class="program-day-schedule"
                      desktopOverflow="bleed"
                    />
                  </article>
                ))
              }
            </div>
          </section>
        </div>

        <aside class="program-secondary-column">
          {
            days.map((day) => (
              <section
                data-program-side={day.date}
                class:list={[
                  "program-side-rail",
                  day.date !== initialDayDate && "hidden",
                ]}
                aria-hidden={day.date === initialDayDate ? "false" : "true"}
              >
                <ProgramDayRail rail={initialRails[day.date]} />
              </section>
            ))
          }
        </aside>
      </div>
    </div>
  </Card>
</section>

<script>
  function syncProgramStageHeight(board) {
    const stage = board.querySelector("[data-program-stage]");
    const activePaper = stage?.querySelector(".program-paper.is-active");
    if (!stage || !activePaper) return;

    const extra = window.matchMedia("(min-width: 1024px)").matches ? 46 : 28;
    stage.style.height = `${Math.ceil(activePaper.getBoundingClientRect().height + extra)}px`;
  }

  document.querySelectorAll("[data-program-board]").forEach((board) => {
    const dayButtons = [...board.querySelectorAll("[data-day-select]")];
    const dayPapers = [...board.querySelectorAll("[data-program-day]")];
    const sidePanels = [...board.querySelectorAll("[data-program-side]")];

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );

    const refreshSidePanel = async (panel, date) => {
      try {
        const res = await fetch(
          `/partials/program-day-rail?date=${encodeURIComponent(date)}`,
        );
        if (!res.ok) throw new Error("Failed to load day rail");
        panel.innerHTML = await res.text();
      } catch {
        return;
      }
    };

    const setSelectedDay = async (date, { refreshRail = false } = {}) => {
      dayButtons.forEach((button) => {
        const isActive = button.dataset.daySelect === date;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", String(isActive));
        button.setAttribute("tabindex", isActive ? "0" : "-1");
      });

      dayPapers.forEach((paper) => {
        const isActive = paper.dataset.programDay === date;
        paper.classList.toggle("is-active", isActive);
        paper.classList.toggle("is-under", !isActive);
        paper.setAttribute("aria-hidden", String(!isActive));

        if (isActive) {
          paper.removeAttribute("inert");
        } else {
          paper.setAttribute("inert", "");
        }
      });

      let activeSidePanel = null;
      sidePanels.forEach((panel) => {
        const isActive = panel.dataset.programSide === date;
        panel.classList.toggle("hidden", !isActive);
        panel.setAttribute("aria-hidden", String(!isActive));
        if (isActive) activeSidePanel = panel;
      });

      requestAnimationFrame(() => syncProgramStageHeight(board));

      if (refreshRail && activeSidePanel) {
        await refreshSidePanel(activeSidePanel, date);
      }
    };

    dayButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        await setSelectedDay(button.dataset.daySelect, { refreshRail: true });
      });
    });

    board.addEventListener("click", async (event) => {
      const jumpButton = event.target.closest("[data-show-day]");
      if (!(jumpButton instanceof HTMLElement)) return;

      const { showDay } = jumpButton.dataset;
      if (!showDay) return;

      await setSelectedDay(showDay, { refreshRail: true });

      if (window.matchMedia("(max-width: 1023px)").matches) {
        const activePaper = board.querySelector(
          `[data-program-day="${showDay}"]`,
        );
        activePaper?.scrollIntoView({
          block: "start",
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
        });
      }
    });

    const resizeObserver =
      "ResizeObserver" in window
        ? new ResizeObserver(() =>
            requestAnimationFrame(() => syncProgramStageHeight(board)),
          )
        : null;

    dayPapers.forEach((paper) => resizeObserver?.observe(paper));

    window.addEventListener("resize", () => syncProgramStageHeight(board));
    document.addEventListener("astro:page-load", () =>
      syncProgramStageHeight(board),
    );
    const initialDate =
      dayButtons.find((button) => button.classList.contains("is-active"))
        ?.dataset.daySelect ?? dayButtons[0]?.dataset.daySelect;

    if (initialDate) {
      setSelectedDay(initialDate);
    } else {
      syncProgramStageHeight(board);
    }
  });
</script>

<style>
  .program-breakout {
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    width: 100vw;
    padding: clamp(1.5rem, 3vw, 3rem) 0;
  }

  :global(.program-shell) {
    width: min(76rem, calc(100vw - 1.5rem));
    margin: 0 auto;
    overflow: visible;
  }

  .program-grid {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .program-primary-column,
  .program-secondary-column {
    display: grid;
    gap: 1rem;
    min-width: 0;
    align-content: start;
  }

  .program-panel-kicker,
  .program-paper-kicker,
  .program-sampled-kicker,
  .program-other-day-meta,
  .program-other-day-time {
    font-family: var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .program-selector-panel,
  .program-main-panel {
    min-width: 0;
  }

  .program-main-panel,
  .program-secondary-column,
  .program-side-rail {
    position: relative;
    z-index: 1;
  }

  .program-selector-panel {
    min-width: 0;
  }

  :global(.program-panel-copy) {
    color: var(--muted-foreground);
    max-width: 62ch;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .program-intro-copy {
    margin-bottom: 1rem;
    max-width: 80ch;
  }

  :global(.program-panel-kicker) {
    margin-top: 0.2rem;
    margin-bottom: 0.38rem;
    color: var(--primary);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .program-day-selector {
    display: grid;
    gap: 0;
    margin-top: 0.35rem;
    padding: 0;
    border: 1px solid color-mix(in oklch, var(--border), transparent 28%);
    border-radius: 1.05rem;
    background: color-mix(in oklch, var(--card), var(--background) 4%);
    overflow: hidden;
    box-shadow: none;
  }

  .program-day-chip {
    position: relative;
    display: grid;
    gap: 0.22rem;
    justify-items: start;
    min-height: 4.85rem;
    padding: 0.82rem 1rem 0.9rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--muted-foreground);
    text-align: left;
    transition:
      color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .program-day-chip + .program-day-chip {
    border-left: 1px solid color-mix(in oklch, var(--border), transparent 18%);
  }

  .program-day-chip:hover {
    color: var(--foreground);
    background: color-mix(in oklch, var(--card), var(--primary) 2%);
  }

  .program-day-chip:focus-visible,
  :global(.program-inline-link:focus-visible),
  :global(.program-other-day-button:focus-visible) {
    outline: none;
    box-shadow: inset 0 0 0 2px
      color-mix(in oklch, var(--primary), transparent 30%);
  }

  .program-day-chip.is-active {
    background: color-mix(in oklch, var(--primary), transparent 94%);
    color: var(--foreground);
    box-shadow: inset 0 0 0 1px
      color-mix(in oklch, var(--primary), transparent 78%);
  }

  .program-day-chip-kicker {
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .program-day-chip-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .program-day-chip-meta {
    color: var(--muted-foreground);
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .program-side-rail {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .program-sampled-header,
  .program-preview-header,
  .program-group-header {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  :global(.program-inline-link) {
    color: var(--muted-foreground);
    font-size: 0.82rem;
    font-weight: 600;
    white-space: nowrap;
    transition: color 180ms ease;
  }

  :global(.program-inline-link:hover) {
    color: var(--foreground);
  }

  :global(.program-sampled-panel),
  :global(.program-preview-panel) {
    display: grid;
    gap: 0.9rem;
  }

  :global(.program-sampled-board) {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  :global(.program-sampled-paper) {
    position: relative;
    border: 1px solid color-mix(in oklch, var(--border), transparent 18%);
    border-radius: 1.25rem;
    background: color-mix(in oklch, var(--card), var(--background) 2%);
    box-shadow: 0 14px 28px rgb(15 23 42 / 0.08);
  }

  :global(.program-sampled-paper::before) {
    content: "";
    position: absolute;
    top: -0.45rem;
    left: 1.2rem;
    width: 2.9rem;
    height: 0.82rem;
    border: 1px dashed color-mix(in oklch, var(--primary), transparent 50%);
    border-radius: 0.35rem;
    background: color-mix(in oklch, var(--primary), white 84%);
    box-shadow: 0 2px 6px rgb(15 23 42 / 0.06);
    pointer-events: none;
  }

  :global(.program-sampled-featured) {
    z-index: 2;
    padding: 1.1rem 1.1rem 1.05rem;
    transform: none;
  }

  :global(.program-sampled-side) {
    display: grid;
    gap: 0.7rem;
  }

  :global(.program-sampled-slip-list) {
    display: grid;
    gap: 0.7rem;
  }

  :global(.program-sampled-slip) {
    padding: 0.85rem 0.9rem;
    transform: none;
  }

  :global(.program-sampled-kicker) {
    margin-top: 0.2rem;
    margin-bottom: 0.35rem;
    color: var(--primary);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  :global(.program-sampled-entry-featured .starring-card-title) {
    display: block;
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.16;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  :global(.program-sampled-entry-featured .starring-card-description) {
    margin-top: 0.8rem;
    max-width: 26ch;
    font-size: 0.94rem;
    line-height: 1.5;
  }

  :global(.program-sampled-entry-featured .starring-card-meta),
  :global(.program-sampled-entry-compact .starring-card-meta) {
    gap: 0.25rem 0.45rem;
    margin-top: 0.45rem;
    font-size: 0.7rem;
  }

  :global(.program-sampled-entry-compact .starring-card-title) {
    display: block;
    font-size: 0.88rem;
    line-height: 1.3;
  }

  :global(.program-sampled-entry-featured .starring-card-time),
  :global(.program-sampled-entry-featured .starring-card-meta .event-badge),
  :global(.program-sampled-entry-compact .starring-card-time),
  :global(.program-sampled-entry-compact .starring-card-meta .event-badge) {
    padding: 0.18rem 0.5rem;
  }

  :global(.program-other-days-list) {
    display: grid;
    gap: 0.8rem;
  }

  :global(.program-other-day-card) {
    position: relative;
    display: grid;
    gap: 0.85rem;
    padding: 0.95rem 1rem 1rem;
    border: 1px dashed
      color-mix(in oklch, var(--event-workshop-sub), transparent 56%);
    border-radius: 1.1rem;
    background: transparent;
    box-shadow: none;
  }

  :global(.program-other-day-card::before) {
    content: "";
    position: absolute;
    top: -0.45rem;
    left: 1rem;
    width: 2.6rem;
    height: 0.72rem;
    border: 1px dashed
      color-mix(in oklch, var(--event-workshop-sub), transparent 44%);
    border-radius: 0.35rem;
    background: color-mix(in oklch, var(--event-workshop-bg), white 34%);
    box-shadow: 0 1px 4px rgb(15 23 42 / 0.03);
    pointer-events: none;
  }

  :global(.program-other-day-header) {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
  }

  :global(.program-other-day-meta) {
    margin-bottom: 0.24rem;
    color: color-mix(in oklch, var(--foreground), var(--background) 42%);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  :global(.program-other-day-title) {
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.2;
    color: var(--foreground);
  }

  :global(.program-other-day-button) {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.95rem;
    border: 1px dashed
      color-mix(in oklch, var(--event-workshop-sub), transparent 54%);
    border-radius: 999px;
    background: transparent;
    color: var(--foreground);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  :global(.program-other-day-button:hover) {
    transform: translateY(-1px);
    border-color: color-mix(
      in oklch,
      var(--event-workshop-sub),
      transparent 34%
    );
    background: color-mix(in oklch, var(--card), transparent 48%);
    color: var(--foreground);
  }

  :global(.program-other-day-agenda) {
    display: grid;
    gap: 0.7rem;
  }

  :global(.program-other-day-item) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
  }

  :global(.program-other-day-time) {
    color: color-mix(in oklch, var(--foreground), var(--background) 34%);
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 1.3;
    white-space: nowrap;
  }

  :global(.program-other-day-item-title) {
    font-size: 0.84rem;
    font-weight: 560;
    line-height: 1.3;
    text-wrap: pretty;
    color: var(--foreground);
  }

  :global(.program-other-day-room) {
    color: color-mix(in oklch, var(--foreground), var(--background) 46%);
    margin-top: 0.12rem;
    font-size: 0.66rem;
    line-height: 1.28;
  }

  .program-stage {
    position: relative;
    isolation: isolate;
    margin-top: 0.75rem;
    padding: 0.45rem 1rem 2rem 0.15rem;
    transition: height 220ms ease;
  }

  .program-stage::before,
  .program-stage::after {
    content: "";
    position: absolute;
    inset: 0 0.65rem 1rem 0.2rem;
    border-radius: 1.3rem;
    border: 1px solid color-mix(in oklch, var(--primary), transparent 76%);
    background: color-mix(in oklch, var(--card), var(--background) 5%);
    pointer-events: none;
  }

  .program-stage::before {
    z-index: 0;
    opacity: 0.92;
    transform: translate(1.2rem, 0.9rem) rotate(1deg);
    box-shadow: 0 16px 26px rgb(15 23 42 / 0.05);
  }

  .program-stage::after {
    z-index: 1;
    opacity: 0.97;
    transform: translate(0.65rem, 0.45rem) rotate(-0.75deg);
    box-shadow: 0 18px 28px rgb(15 23 42 / 0.06);
  }

  .program-paper {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1.3rem;
    border-radius: 1.2rem;
    border: 1px solid color-mix(in oklch, var(--border), transparent 20%);
    background: var(--card);
    box-shadow: 0 16px 36px rgb(15 23 42 / 0.08);
    transition:
      transform 240ms ease,
      opacity 220ms ease,
      box-shadow 220ms ease,
      filter 220ms ease;
  }

  .program-paper::before {
    content: "";
    position: absolute;
    top: -0.55rem;
    width: 4.75rem;
    height: 1rem;
    border-radius: 0.3rem;
    border: 2px dashed color-mix(in oklch, var(--primary), transparent 45%);
    background: color-mix(in oklch, var(--primary), white 82%);
  }

  .program-paper-a::before {
    left: 1.4rem;
    transform: rotate(-3deg);
  }

  .program-paper-b::before {
    right: 1.5rem;
    transform: rotate(3deg);
  }

  .program-paper.is-active {
    opacity: 1;
    transform: translate(0, 0) rotate(-0.35deg);
    box-shadow: 0 20px 42px rgb(15 23 42 / 0.11);
    filter: none;
    pointer-events: auto;
  }

  .program-paper.is-under {
    opacity: 0;
    transform: translate(0.65rem, 0.75rem) rotate(0.65deg) scale(0.992);
    box-shadow: none;
    filter: saturate(0.94);
    pointer-events: none;
  }

  .program-paper-header {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .program-paper-kicker {
    margin-bottom: 0.3rem;
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .program-paper-title {
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .program-paper-subtitle {
    margin-top: 0.2rem;
    color: var(--muted-foreground);
    font-size: 0.98rem;
  }

  .program-paper-summary {
    display: inline-flex;
    flex: none;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.65rem 0.85rem;
    border: 1px dashed color-mix(in oklch, var(--primary), transparent 35%);
    border-radius: 0.95rem;
    background: color-mix(in oklch, var(--primary), transparent 94%);
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .program-paper :global(.day-schedule) {
    border-color: color-mix(in oklch, var(--primary), transparent 72%);
    background: color-mix(in oklch, var(--card), var(--background) 6%);
    overflow: hidden;
  }

  .program-paper :global(.day-schedule .border-border),
  .program-paper :global(.day-schedule .divide-border) {
    border-color: color-mix(in oklch, var(--primary), transparent 78%);
  }

  .program-paper :global(.day-schedule .divide-border\/40) {
    border-color: color-mix(in oklch, var(--primary), transparent 84%);
  }

  .hidden {
    display: none;
  }

  @media (min-width: 1024px) {
    .program-grid {
      grid-template-columns: minmax(0, 1.62fr) minmax(19rem, 0.86fr);
      gap: 1.75rem;
      grid-template-areas:
        "selector selector"
        "main spotlight";
    }

    .program-selector-panel {
      grid-area: selector;
    }

    .program-primary-column {
      grid-area: main;
    }

    .program-secondary-column {
      grid-area: spotlight;
      padding-top: 0.45rem;
      z-index: 3;
    }

    :global(.program-sampled-board) {
      grid-template-columns: 1fr;
    }

    .program-day-selector {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: stretch;
    }

    .program-paper {
      padding-right: 1.65rem;
    }

    .program-paper :global(.program-day-schedule) {
      margin-left: -1rem;
      margin-right: -1.05rem;
    }
