---
import PaperCard from "@/components/ui/PaperCard.astro";
import SectionKicker from "@/components/ui/SectionKicker.astro";
import StarringCard from "./StarringCard.astro";

interface Speaker {
  name: string;
  id?: string;
}

interface Talk {
  id: string;
  title: string;
  speakers?: Speaker[];
  typeName: string;
  start?: string;
  description?: string;
}

interface Props {
  talks: Talk[];
}

const { talks } = Astro.props;
const [featured, ...rest] = talks;
const slips = rest.slice(0, 3);

const slipRotations = [0.5, -0.35, 0.3];
---

{
  featured ? (
    <div class="talks-board">
      <PaperCard
        variant="solid"
        rotation={-0.45}
        tapePosition="left"
        tapeWidth="md"
        class="talks-paper-featured"
      >
        <SectionKicker text="picked at random" class="talks-kicker" />
        <StarringCard
          talkId={featured.id}
          title={featured.title}
          speakers={featured.speakers}
          typeName={featured.typeName}
          start={featured.start}
          description={featured.description}
          variant="featured"
          class="talks-entry-featured"
        />
      </PaperCard>

      <aside class="talks-side-stack" aria-label="More featured talks">
        <SectionKicker text="more in the stack" class="talks-side-kicker" />
        <div class="talks-slip-list">
          {
            slips.map((talk, index) => (
              <PaperCard
                variant="solid"
                rotation={slipRotations[index]}
                tapePosition="left"
                tapeWidth="md"
                class="talks-slip"
              >
                <StarringCard
                  talkId={talk.id}
                  title={talk.title}
                  speakers={talk.speakers}
                  typeName={talk.typeName}
                  start={talk.start}
                  description={talk.description}
                  variant="compact"
                  class="talks-entry-compact"
                />
              </PaperCard>
            ))
          }
        </div>
      </aside>
    </div>
  ) : (
    <p class="text-muted-foreground">Talks are still lining up.</p>
  )
}

<style>
  .talks-board {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  :global(.talks-paper-featured) {
    padding: 1.2rem 1.3rem 1.1rem;
  }

  :global(.talks-kicker) {
    margin: 0 0 0.75rem;
  }

  .talks-side-stack {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  :global(.talks-side-kicker) {
    margin-bottom: 0;
    padding-left: 0.4rem;
  }

  .talks-slip-list {
    display: grid;
    gap: 0.8rem;
  }

  :global(.talks-slip) {
    padding: 0.95rem 1rem;
  }

  :global(.talks-entry-featured .starring-card-title) {
    display: block;
    margin-bottom: 0.1rem;
  }

  :global(.talks-entry-featured .starring-card-meta) {
    gap: 0.5rem 0.7rem;
    margin-top: 0.75rem;
  }

  :global(.talks-entry-featured .starring-card-arrow) {
    margin-top: 0.15rem;
  }

  :global(.talks-entry-compact .starring-card-title) {
    display: block;
    line-height: 1.35;
  }

  :global(.talks-entry-compact .starring-card-meta) {
    gap: 0.3rem 0.55rem;
    margin-top: 0.5rem;
  }

  @media (min-width: 900px) {
    .talks-board {
      grid-template-columns: minmax(0, 1.35fr) minmax(15rem, 0.92fr);
      gap: 1.15rem;
    }

    .talks-side-stack {
      padding-top: 1.1rem;
    }
  }

  @media (max-width: 639px) {
    :global(.talks-paper-featured),
    :global(.talks-slip) {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    :global(.talks-slip:nth-child(n + 4)) {
      display: none;
    }
  }
</style>
