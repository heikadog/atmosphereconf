---
import type { ProgramRail } from "@/lib/program";
import { formatMiniTime } from "@/lib/program";
import PaperCard from "@/components/ui/PaperCard.astro";
import PanelHeader from "@/components/ui/PanelHeader.astro";
import SectionKicker from "@/components/ui/SectionKicker.astro";
import StarringCard from "./StarringCard.astro";

interface Props {
  rail: ProgramRail;
}

const { rail } = Astro.props;
---

<section class="rail-sampled-panel">
  <PanelHeader
    kicker={`Some random (${rail.dayLabel}) picks`}
    linkHref="/talks"
    linkText="see all"
  />

  <button class="rail-lucky-btn" data-rail-shuffle>
    <span class="rail-lucky-goose" aria-hidden="true">🪿</span>
    <span class="rail-lucky-label">I'm feeling curious</span>
  </button>

  <div class="rail-sampled-board">
    {
      rail.spotlight && (
        <PaperCard
          variant="outline"
          tapePosition="left"
          tapeWidth="md"
          class="rail-sampled-featured"
        >
          <StarringCard
            talkId={rail.spotlight.id}
            title={rail.spotlight.title}
            speakers={rail.spotlight.speakers}
            typeName={rail.spotlight.typeName}
            start={rail.spotlight.start}
            description={rail.spotlight.description}
            variant="featured"
            metaLayout="stacked"
            class="rail-entry-featured"
          />
        </PaperCard>
      )
    }

    <aside class="rail-sampled-side">
      <div class="rail-slip-list">
        {
          rail.suggestions.map((event) => (
            <PaperCard
              variant="outline"
              tapePosition="left"
              tapeWidth="md"
              class="rail-sampled-slip"
            >
              <StarringCard
                talkId={event.id}
                title={event.title}
                speakers={event.speakers}
                typeName={event.typeName}
                start={event.start}
                variant="compact"
                metaLayout="stacked"
                class="rail-entry-compact"
              />
            </PaperCard>
          ))
        }
      </div>
    </aside>
  </div>
</section>

{
  rail.otherDays.length > 0 && (
    <section class="rail-preview-panel">
      <PanelHeader kicker="Sampling the other days" />

      <div class="rail-other-days-list">
        {rail.otherDays.map((otherDay) => (
          <PaperCard
            variant="dashed"
            tapePosition="left"
            tapeWidth="sm"
            class="rail-other-day-card"
          >
            <div class="rail-other-day-header">
              <a
                href={`#${otherDay.anchorId}`}
                class="rail-other-day-link"
                data-show-day={otherDay.date}
              >
                <p class="rail-other-day-meta">{`${otherDay.dayLabel} · ${otherDay.seriesLabel}`}</p>
                <h4 class="rail-other-day-title">{otherDay.dateLabel}</h4>
              </a>
              <a
                href={`#${otherDay.anchorId}`}
                class="rail-other-day-button"
                data-show-day={otherDay.date}
                aria-label={`Show ${otherDay.heading} in the main schedule`}
              >
                Show day
              </a>
            </div>

            <ol class="rail-other-day-agenda">
              {otherDay.picks.map((event) => (
                <li class="rail-other-day-item">
                  <span class="rail-other-day-time">
                    {formatMiniTime(event.start)}
                  </span>
                  <div class="min-w-0">
                    <p
                      class="rail-other-day-item-title"
                      set:html={event.title}
                    />
                    {event.room && (
                      <p class="rail-other-day-room">{event.room}</p>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </PaperCard>
        ))}
      </div>
    </section>
  )
}

<style>
  .rail-sampled-panel,
  .rail-preview-panel {
    display: grid;
    gap: 0.9rem;
  }

  .rail-sampled-board {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  :global(.rail-sampled-featured) {
    z-index: 2;
    padding: 1.4rem 1.35rem 1.3rem;
    background: color-mix(in oklch, var(--primary), transparent 97%);
    border-color: color-mix(in oklch, var(--primary), transparent 78%);
    box-shadow: var(--paper-shadow-lg);
  }

  .rail-sampled-side {
    display: grid;
    gap: 0.7rem;
  }

  .rail-slip-list {
    display: grid;
    gap: 0.7rem;
  }

  :global(.rail-sampled-slip) {
    padding: 0.75rem 0.85rem;
    opacity: 0.88;
  }

  :global(.rail-kicker) {
    margin-top: 0.2rem;
    margin-bottom: 0.35rem;
  }

  :global(.rail-entry-featured .starring-card-arrow) {
    font-size: 1.15rem;
    color: var(--primary);
    opacity: 0.6;
  }

  :global(.rail-entry-featured .starring-card-title) {
    display: block;
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  :global(.rail-entry-featured .starring-card-description) {
    margin-top: 0.8rem;
    max-width: 26ch;
    font-size: 0.94rem;
    line-height: 1.5;
  }

  :global(.rail-entry-featured .starring-card-meta) {
    gap: 0.3rem 0.5rem;
    margin-top: 0.65rem;
    font-size: 0.73rem;
  }

  :global(.rail-entry-compact .starring-card-meta) {
    gap: 0.25rem 0.45rem;
    margin-top: 0.35rem;
    font-size: 0.68rem;
  }

  :global(.rail-entry-compact .starring-card-title) {
    display: block;
    font-size: 0.84rem;
    line-height: 1.28;
  }

  :global(
    .rail-entry-featured
      .starring-card-meta
      :is(.starring-card-time, .event-badge)
  ),
  :global(
    .rail-entry-compact
      .starring-card-meta
      :is(.starring-card-time, .event-badge)
  ) {
    padding: 0.18rem 0.5rem;
  }

  .rail-other-days-list {
    display: grid;
    gap: 0.8rem;
  }

  :global(.rail-other-day-card) {
    padding: 0.95rem 1rem 1rem;
    border-radius: var(--paper-radius-sm);
  }

  .rail-other-day-header {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .rail-other-day-link {
    text-decoration: none;
    color: inherit;
  }

  .rail-other-day-link:hover .rail-other-day-title {
    color: var(--primary);
  }

  .rail-other-day-meta {
    margin-bottom: 0.24rem;
    color: color-mix(in oklch, var(--foreground), var(--background) 42%);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .rail-other-day-title {
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.2;
    color: var(--foreground);
  }

  .rail-other-day-button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.95rem;
    border: 2px var(--pill-border-style, dashed)
      color-mix(in oklch, var(--event-workshop-sub), transparent 54%);
    border-radius: var(--pill-radius);
    background: transparent;
    color: var(--foreground);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .rail-other-day-button:hover {
    transform: translateY(-1px);
    border-color: color-mix(
      in oklch,
      var(--event-workshop-sub),
      transparent 34%
    );
    background: color-mix(in oklch, var(--card), transparent 48%);
    color: var(--foreground);
  }

  .rail-other-day-button:focus-visible {
    outline: 2px solid color-mix(in oklch, var(--primary), transparent 30%);
    outline-offset: -2px;
  }

  .rail-other-day-agenda {
    display: grid;
    gap: 0.7rem;
    list-style: none;
    padding: 0;
  }

  .rail-other-day-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
  }

  .rail-other-day-time {
    color: color-mix(in oklch, var(--foreground), var(--background) 34%);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.3;
    white-space: nowrap;
  }

  .rail-other-day-item-title {
    font-size: 0.84rem;
    font-weight: 560;
    line-height: 1.3;
    text-wrap: pretty;
    color: var(--foreground);
  }

  .rail-other-day-room {
    color: color-mix(in oklch, var(--foreground), var(--background) 46%);
    margin-top: 0.12rem;
    font-size: 0.66rem;
    line-height: 1.28;
  }

  @media (min-width: 1024px) {
    :global(.rail-sampled-board) {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    :global(.rail-sampled-featured),
    :global(.rail-sampled-slip) {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .rail-other-day-header {
      flex-direction: column;
    }

    .rail-other-day-button {
      align-self: flex-start;
    }
  }

  .rail-lucky-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
    padding: 0.65rem 1rem;
    border: 1px dashed color-mix(in oklch, var(--primary), transparent 55%);
    border-radius: var(--pill-radius);
    background: color-mix(in oklch, var(--card), var(--primary) 8%);
    color: color-mix(in oklch, var(--foreground), var(--primary) 18%);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .rail-lucky-goose {
    display: inline-block;
    font-size: 1.1em;
    transition: transform 200ms ease;
  }

  .rail-lucky-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    border-color: color-mix(in oklch, var(--primary), transparent 28%);
    background: color-mix(in oklch, var(--card), var(--primary) 14%);
  }

  .rail-lucky-btn:hover:not(:disabled) .rail-lucky-goose {
    animation: goose-waddle 400ms ease infinite;
  }

  .rail-lucky-btn:active:not(:disabled) {
    transform: translateY(1px);
    transition-duration: 60ms;
  }

  .rail-lucky-btn:disabled {
    cursor: wait;
  }

  .rail-lucky-btn:disabled .rail-lucky-goose {
    animation: goose-walk 600ms ease infinite;
  }

  @keyframes goose-waddle {
    0%,
    100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-8deg);
    }
    75% {
      transform: rotate(8deg);
    }
  }

  @keyframes goose-walk {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-2px) rotate(-5deg);
    }
    75% {
      transform: translateX(2px) rotate(5deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail-other-day-button,
    .rail-lucky-btn {
      transition: none;
    }

    .rail-lucky-btn:hover:not(:disabled) .rail-lucky-goose,
    .rail-lucky-btn:disabled .rail-lucky-goose {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest(
      "[data-rail-shuffle]",
    ) as HTMLButtonElement | null;
    if (!btn) return;

    const panel = btn.closest("[data-program-side]") as HTMLElement | null;
    const date = panel?.dataset.programSide ?? "";

    const label = btn.querySelector(".rail-lucky-label");
    const shuffleMessages = [
      "Going on a goose chase\u2026",
      "Taking a gander\u2026",
      "Pecking the schedule\u2026",
      "Fowling around\u2026",
      "Honk for open data\u2026",
    ];

    if (label) {
      label.textContent =
        shuffleMessages[Math.floor(Math.random() * shuffleMessages.length)];
    }
    btn.disabled = true;

    try {
      const [res] = await Promise.all([
        fetch(`/partials/program-day-rail?date=${encodeURIComponent(date)}`),
        new Promise((r) => setTimeout(r, 600)),
      ]);
      if (!(res as Response).ok) throw new Error("fetch failed");
      const parent = btn.closest(".rail-sampled-panel") as HTMLElement;
      const tmp = document.createElement("div");
      tmp.innerHTML = await (res as Response).text();
      const newPanel = tmp.querySelector(".rail-sampled-panel");
      if (newPanel && parent) {
        parent.replaceWith(newPanel);
      }
    } catch {
      if (label) label.textContent = "Honk! Something went wrong";
      btn.disabled = false;
    }
  });
</script>
