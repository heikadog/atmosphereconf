---
import type { ProgramRail } from "@/lib/program";
import { formatMiniTime } from "@/lib/program";
import PaperCard from "@/components/ui/PaperCard.astro";
import PanelHeader from "@/components/ui/PanelHeader.astro";
import SectionKicker from "@/components/ui/SectionKicker.astro";
import StarringCard from "./StarringCard.astro";

interface Props {
  rail: ProgramRail;
}

const { rail } = Astro.props;
---

<section class="rail-sampled-panel">
  <PanelHeader
    kicker={`${rail.dayLabel} picks`}
    linkHref="/talks"
    linkText="see all talks"
  />

  <div class="rail-sampled-board">
    {
      rail.spotlight && (
        <PaperCard variant="outline" tapePosition="left" tapeWidth="md" class="rail-sampled-featured">
          <SectionKicker text="random highlight" class="rail-kicker" />
          <StarringCard
            talkId={rail.spotlight.id}
            title={rail.spotlight.title}
            speakers={rail.spotlight.speakers}
            typeName={rail.spotlight.typeName}
            start={rail.spotlight.start}
            description={rail.spotlight.description}
            variant="featured"
            metaLayout="stacked"
            class="rail-entry-featured"
          />
        </PaperCard>
      )
    }

    <aside class="rail-sampled-side">
      <SectionKicker text="a few more" class="rail-kicker" />
      <div class="rail-slip-list">
        {
          rail.suggestions.map((event) => (
            <PaperCard variant="outline" tapePosition="left" tapeWidth="md" class="rail-sampled-slip">
              <StarringCard
                talkId={event.id}
                title={event.title}
                speakers={event.speakers}
                typeName={event.typeName}
                start={event.start}
                variant="compact"
                metaLayout="stacked"
                class="rail-entry-compact"
              />
            </PaperCard>
          ))
        }
      </div>
    </aside>
  </div>
</section>

<section class="rail-preview-panel">
  <PanelHeader kicker="from the other days" />

  <div class="rail-other-days-list">
    {
      rail.otherDays.map((otherDay) => (
        <PaperCard variant="dashed" tapePosition="left" tapeWidth="sm" class="rail-other-day-card">
          <div class="rail-other-day-header">
            <div>
              <p class="rail-other-day-meta">{`${otherDay.dayLabel} · ${otherDay.seriesLabel}`}</p>
              <h4 class="rail-other-day-title">{otherDay.dateLabel}</h4>
            </div>
            <button
              type="button"
              class="rail-other-day-button"
              data-show-day={otherDay.date}
              aria-label={`Show ${otherDay.heading} in the main schedule`}
            >
              Show day
            </button>
          </div>

          <ol class="rail-other-day-agenda">
            {otherDay.picks.map((event) => (
              <li class="rail-other-day-item">
                <span class="rail-other-day-time">
                  {formatMiniTime(event.start)}
                </span>
                <div class="min-w-0">
                  <p class="rail-other-day-item-title" set:html={event.title} />
                  {event.room && (
                    <p class="rail-other-day-room">{event.room}</p>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </PaperCard>
      ))
    }
  </div>
</section>

<style>
  .rail-sampled-panel,
  .rail-preview-panel {
    display: grid;
    gap: 0.9rem;
  }

  .rail-sampled-board {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  :global(.rail-sampled-featured) {
    z-index: 2;
    padding: 1.1rem 1.1rem 1.05rem;
  }

  .rail-sampled-side {
    display: grid;
    gap: 0.7rem;
  }

  .rail-slip-list {
    display: grid;
    gap: 0.7rem;
  }

  :global(.rail-sampled-slip) {
    padding: 0.85rem 0.9rem;
  }

  :global(.rail-kicker) {
    margin-top: 0.2rem;
    margin-bottom: 0.35rem;
  }

  :global(.rail-entry-featured .starring-card-title) {
    display: block;
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.16;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  :global(.rail-entry-featured .starring-card-description) {
    margin-top: 0.8rem;
    max-width: 26ch;
    font-size: 0.94rem;
    line-height: 1.5;
  }

  :global(.rail-entry-featured .starring-card-meta),
  :global(.rail-entry-compact .starring-card-meta) {
    gap: 0.25rem 0.45rem;
    margin-top: 0.45rem;
    font-size: 0.7rem;
  }

  :global(.rail-entry-compact .starring-card-title) {
    display: block;
    font-size: 0.88rem;
    line-height: 1.3;
  }

  :global(.rail-entry-featured .starring-card-meta :is(.starring-card-time, .event-badge)),
  :global(.rail-entry-compact .starring-card-meta :is(.starring-card-time, .event-badge)) {
    padding: 0.18rem 0.5rem;
  }

  .rail-other-days-list {
    display: grid;
    gap: 0.8rem;
  }

  :global(.rail-other-day-card) {
    padding: 0.95rem 1rem 1rem;
    border-radius: var(--paper-radius-sm);
  }

  .rail-other-day-header {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .rail-other-day-meta {
    margin-bottom: 0.24rem;
    color: color-mix(in oklch, var(--foreground), var(--background) 42%);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .rail-other-day-title {
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.2;
    color: var(--foreground);
  }

  .rail-other-day-button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.95rem;
    border: 2px var(--pill-border-style, dashed)
      color-mix(in oklch, var(--event-workshop-sub), transparent 54%);
    border-radius: var(--pill-radius);
    background: transparent;
    color: var(--foreground);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .rail-other-day-button:hover {
    transform: translateY(-1px);
    border-color: color-mix(
      in oklch,
      var(--event-workshop-sub),
      transparent 34%
    );
    background: color-mix(in oklch, var(--card), transparent 48%);
    color: var(--foreground);
  }

  .rail-other-day-button:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 2px
      color-mix(in oklch, var(--primary), transparent 30%);
  }

  .rail-other-day-agenda {
    display: grid;
    gap: 0.7rem;
    list-style: none;
    padding: 0;
  }

  .rail-other-day-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
  }

  .rail-other-day-time {
    color: color-mix(in oklch, var(--foreground), var(--background) 34%);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.3;
    white-space: nowrap;
  }

  .rail-other-day-item-title {
    font-size: 0.84rem;
    font-weight: 560;
    line-height: 1.3;
    text-wrap: pretty;
    color: var(--foreground);
  }

  .rail-other-day-room {
    color: color-mix(in oklch, var(--foreground), var(--background) 46%);
    margin-top: 0.12rem;
    font-size: 0.66rem;
    line-height: 1.28;
  }

  @media (min-width: 1024px) {
    :global(.rail-sampled-board) {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    :global(.rail-sampled-featured),
    :global(.rail-sampled-slip) {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .rail-other-day-header {
      flex-direction: column;
    }

    .rail-other-day-button {
      align-self: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail-other-day-button {
      transition: none;
    }
  }
</style>
