---
import Card from "@/components/ui/card.astro";
import RandomTalkDeck from "./RandomTalkDeck.astro";
import { getRandomTalks } from "@/lib/talks";

const starred = await getRandomTalks();
---

<section>
  <Card title="talks" class="talks-shell">
    <p class="text-muted-foreground max-w-[62ch]">
      A shuffled sample from the program. Pull another stack if you want a
      different slice of the lineup.
    </p>
    <div id="starring-list" class="mt-5">
      <RandomTalkDeck talks={starred} />
    </div>
    <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <button
        id="show-more-talks"
        class="talks-refresh"
      >
        Pull another stack
      </button>
      <a
        href="/talks"
        class="starring-see-all text-muted-foreground hover:text-foreground text-sm transition-colors"
      >
        See them all &rarr;
      </a>
    </div>
  </Card>
</section>

<script>
  const btn = document.getElementById("show-more-talks");
  const list = document.getElementById("starring-list");

  // Event delegation for bsky profile links
  list?.addEventListener("click", (e) => {
    const el = (e.target as HTMLElement).closest(
      "[data-profile-href]",
    ) as HTMLElement | null;
    if (el) {
      e.preventDefault();
      e.stopPropagation();
      window.location.href = el.dataset.profileHref!;
    }
  });

  btn?.addEventListener("click", async () => {
    btn.textContent = "Pulling...";
    btn.setAttribute("disabled", "true");
    try {
      const res = await fetch("/partials/random-talks");
      list!.innerHTML = await res.text();
    } catch {
      btn.textContent = "Something went wrong";
      btn.removeAttribute("disabled");
      return;
    }
    btn.textContent = "Pull another stack";
    btn.removeAttribute("disabled");
  });
</script>

<style>
  :global(.talks-shell) {
    overflow: visible;
  }

  .talks-refresh {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 12rem;
    padding: 0.85rem 1.1rem;
    border: 1px dashed color-mix(in oklch, var(--primary), transparent 35%);
    border-radius: 9999px;
    background: color-mix(in oklch, var(--card), var(--background) 12%);
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .talks-refresh:hover:not(:disabled) {
    transform: translateY(-1px);
    border-color: color-mix(in oklch, var(--primary), transparent 12%);
    background: color-mix(in oklch, var(--primary), transparent 93%);
  }

  .talks-refresh:disabled {
    opacity: 0.75;
    cursor: wait;
  }
</style>
