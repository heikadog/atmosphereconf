---
import BreakoutSection from "@/components/ui/BreakoutSection.astro";
import Card from "@/components/ui/card.astro";
import ProgramDayRail from "./ProgramDayRail.astro";
import { getProgramDays, getRandomProgramRail, talkDates } from "@/lib/program";

const days = await getProgramDays();
const talkDays = days.filter((d) => talkDates.includes(d.date));

const rails = talkDays.flatMap((day) => {
  const rail = getRandomProgramRail(day.date, talkDays);
  if (!rail) return [];
  rail.otherDays = [];
  return [{ date: day.date, rail }];
});
---

<BreakoutSection maxWidth="74rem" id="talks">
  <Card title="talks" class="starring-card">
    <button class="starring-shuffle-btn" id="starring-shuffle">
      <span class="starring-goose" aria-hidden="true">🪿</span>
      <span class="starring-shuffle-label">I'm feeling curious</span>
    </button>
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-8">
      {
        rails.map(({ date, rail }) => (
          <div data-program-side={date}>
            <ProgramDayRail rail={rail} />
          </div>
        ))
      }
    </div>
  </Card>
</BreakoutSection>

<script>
  const btn = document.getElementById(
    "starring-shuffle",
  ) as HTMLButtonElement | null;
  const label = btn?.querySelector(".starring-shuffle-label");

  const shuffleMessages = [
    "Going on a goose chase\u2026",
    "Taking a gander\u2026",
    "Pecking the schedule\u2026",
    "Fowling around\u2026",
    "Honk for open data\u2026",
  ];

  btn?.addEventListener("click", async () => {
    if (label) {
      label.textContent =
        shuffleMessages[Math.floor(Math.random() * shuffleMessages.length)];
    }
    btn.disabled = true;

    try {
      const panels = btn
        .closest(".starring-card")
        ?.querySelectorAll("[data-program-side]");
      if (!panels) throw new Error("no panels");

      const [results] = await Promise.all([
        Promise.all(
          Array.from(panels).map(async (panel) => {
            const date = (panel as HTMLElement).dataset.programSide ?? "";
            const res = await fetch(
              `/partials/program-day-rail?date=${encodeURIComponent(date)}`,
            );
            if (!res.ok) throw new Error("fetch failed");
            return { panel, html: await res.text() };
          }),
        ),
        new Promise((r) => setTimeout(r, 600)),
      ]);

      for (const { panel, html } of results as {
        panel: Element;
        html: string;
      }[]) {
        const tmp = document.createElement("div");
        tmp.innerHTML = html;
        const newContent = tmp.querySelector(".rail-sampled-panel");
        const oldContent = panel.querySelector(".rail-sampled-panel");
        if (newContent && oldContent) {
          oldContent.replaceWith(newContent);
        }
      }
    } catch {
      if (label) label.textContent = "Honk! Something went wrong";
      btn.disabled = false;
      return;
    }

    if (label) label.textContent = "I'm feeling curious";
    btn.disabled = false;
  });
</script>

<style>
  /* Hide per-rail buttons — we use a single shared one */
  :global(.starring-card .rail-lucky-btn) {
    display: none;
  }

  .starring-shuffle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
    align-self: flex-start;
    margin-bottom: 0.5rem;
    padding: 0.65rem 1rem;
    border: 1px dashed color-mix(in oklch, var(--primary), transparent 55%);
    border-radius: var(--pill-radius);
    background: color-mix(in srgb, var(--card), var(--primary) 8%);
    color: color-mix(in oklch, var(--foreground), var(--primary) 18%);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .starring-goose {
    display: inline-block;
    font-size: 1.1em;
    transition: transform 200ms ease;
  }

  .starring-shuffle-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    border-color: color-mix(in oklch, var(--primary), transparent 28%);
    background: color-mix(in srgb, var(--card), var(--primary) 14%);
  }

  .starring-shuffle-btn:hover:not(:disabled) .starring-goose {
    animation: goose-waddle 400ms ease infinite;
  }

  .starring-shuffle-btn:active:not(:disabled) {
    transform: translateY(1px);
    transition-duration: 60ms;
  }

  .starring-shuffle-btn:disabled {
    cursor: wait;
  }

  .starring-shuffle-btn:disabled .starring-goose {
    animation: goose-walk 600ms ease infinite;
  }

  @keyframes goose-waddle {
    0%,
    100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-8deg);
    }
    75% {
      transform: rotate(8deg);
    }
  }

  @keyframes goose-walk {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-2px) rotate(-5deg);
    }
    75% {
      transform: translateX(2px) rotate(5deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .starring-shuffle-btn {
      transition: none;
    }

    .starring-shuffle-btn:hover:not(:disabled) .starring-goose,
    .starring-shuffle-btn:disabled .starring-goose {
      animation: none;
    }
  }
</style>
