---
import Card from "@/components/ui/card.astro";
import BreakoutSection from "@/components/ui/BreakoutSection.astro";
import PanelHeader from "@/components/ui/PanelHeader.astro";
import PaperCard from "@/components/ui/PaperCard.astro";
import SponsorsCard from "@/components/shared/SponsorsCard.astro";
import { getCollection, getEntry } from "astro:content";

const sponsors = await getCollection("sponsors");
const bskySponsor = await getEntry("sponsors", "bsky")!;
const streamplaceSponsor = await getEntry("sponsors", "streamplace")!;

const majorSponsors = sponsors.filter((s) => s.data.level === "major");
const tierSponsors = sponsors.filter((s) => s.data.level === "sponsor");
const communitySponsors = sponsors.filter((s) => s.data.level === "community");
---

<BreakoutSection maxWidth="74rem" id="sponsors">
  <Card title="sponsors" class="!overflow-visible">
    <div class="grid gap-4 sm:grid-cols-2 sm:gap-[1.1rem]">
      <PaperCard
        variant="outline"
        tapePosition="left"
        tapeWidth="lg"
        class="!rounded-[var(--paper-radius-sm)]"
      >
        <div class="p-[1.2rem] sm:p-6">
          <PanelHeader kicker="Title sponsor" />
          <p class="text-muted-foreground mt-2 mb-4 text-sm">
            A huge thank you to Bluesky for being our title sponsor.
          </p>
          <SponsorsCard sponsor={bskySponsor} />
        </div>
      </PaperCard>

      <PaperCard
        variant="outline"
        tapePosition="right"
        tapeWidth="lg"
        class="!rounded-[var(--paper-radius-sm)]"
      >
        <div class="p-[1.2rem] sm:p-6">
          <PanelHeader kicker="Video partner" />
          <p class="text-muted-foreground mt-2 mb-4 text-sm">
            <a href="https://stream.place" class="text-primary underline"
              >Streamplace</a
            > is streaming up to 3 rooms and powering chat as part of our remote
            track.
          </p>
          <SponsorsCard sponsor={streamplaceSponsor} />
        </div>
      </PaperCard>
    </div>

    {
      majorSponsors.length > 0 && (
        <PaperCard
          variant="outline"
          tapePosition="left"
          tapeWidth="lg"
          class="mt-5 !rounded-[var(--paper-radius-sm)]"
        >
          <div class="p-[1.2rem] sm:p-6">
            <PanelHeader kicker="Major sponsors" />
            <div class="grid grid-cols-2 sm:grid-cols-3 items-stretch gap-3 mt-2">
              {majorSponsors.map((sponsor) => (
                <SponsorsCard sponsor={sponsor} />
              ))}
            </div>
          </div>
        </PaperCard>
      )
    }

    <div class="mt-6 grid gap-5">
      {
        tierSponsors.length > 0 && (
          <div>
            <PanelHeader kicker="Other sponsors" />
            <div class="grid grid-cols-2 sm:grid-cols-3 items-stretch gap-3 mt-2">
              {tierSponsors.map((sponsor) => (
                <SponsorsCard sponsor={sponsor} />
              ))}
            </div>
          </div>
        )
      }

      {
        communitySponsors.length > 0 && (
          <div>
            <PanelHeader kicker="Community" />
            <div class="grid grid-cols-2 sm:grid-cols-3 items-stretch gap-3 mt-2">
              {communitySponsors.map((sponsor) => (
                <SponsorsCard sponsor={sponsor} />
              ))}
            </div>
          </div>
        )
      }
    </div>
  </Card>
</BreakoutSection>
