---
import { FlippableProfileCard } from "@/components/profile/FlippableProfileCard";
import { getActiveIcons } from "@/components/profile/lexicon-icons";
import { getTalksByHandle } from "@/lib/talks";
import { fetchAuthorFeedPage } from "@/lib/bsky";
import { getConnectionCount } from "@/lib/connections";
import type { LoadedProfile } from "@/lib/profile";
import type { ProfileEditData } from "@/components/profile/ProfileView";

interface Props {
  profile: LoadedProfile;
  editData?: ProfileEditData;
  viewerDid?: string;
  isTicketHolder?: boolean;
  ticketEditUrl?: string;
}

const { profile, editData, viewerDid, isTicketHolder = false, ticketEditUrl } = Astro.props;

const svgFiles = import.meta.glob<string>(
  "/src/components/profile/icons/*.svg",
  {
    query: "?raw",
    import: "default",
    eager: true,
  },
);
const svgMap: Record<string, string> = Object.fromEntries(
  Object.entries(svgFiles).map(([path, svg]) => [
    path.replace(/.*\//, "").replace(".svg", ""),
    svg,
  ]),
);

const activeIcons = getActiveIcons(profile.collections).map((icon) => ({
  label: icon.label,
  html: svgMap[icon.svgName] ?? "",
  href: icon.url?.(profile.handle, profile.did),
}));

const talks = await getTalksByHandle(profile.handle);

let authorFeedInitialData;
try {
  authorFeedInitialData = await fetchAuthorFeedPage(profile.did);
} catch {
  authorFeedInitialData = { posts: [], cursor: undefined };
}

let connectionCount = 0;
try {
  connectionCount = await getConnectionCount(profile.did);
} catch {
  // non-critical
}
---

<style is:global>
  html,
  body {
    overflow: hidden;
    height: 100%;
  }
</style>
<div class="flex w-full flex-1 items-center overflow-hidden">
  <FlippableProfileCard
    client:load
    {...profile}
    viewerDid={viewerDid}
    isOwnProfile={!!editData}
    activeIcons={activeIcons}
    editData={editData}
    talks={talks}
    authorFeedInitialData={authorFeedInitialData}
    isTicketHolder={isTicketHolder}
    ticketEditUrl={ticketEditUrl}
    connectionCount={connectionCount}
  />
</div>
